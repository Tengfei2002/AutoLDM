function real Tanh;
input var_g;
real var_g;

begin
    Tanh = (1.0 - exp(-2.0 * var_g)) / (1.0 + exp(-2.0 * var_g));
end
endfunction

function real Sigmoid;
input var_l;
real var_l;

begin
    Sigmoid = 1.0 / (1.0 + exp(-1.0 * var_l));
end
endfunction

