// [中文注释] 本文件由 Hspice\fusion_ic_pmos_lvt.va 派生，仅增加中文说明注释；删除所有 // [中文注释] 行后应与原文件一致。
// [中文注释] 模型类型：PHIMO-Fusion GAA PMOS LVT Verilog-A 紧凑模型。
//*********************************************************************//
//*                 PKU PHIMO-Fusion Model - Verilog-A                *//
//*********************************************************************//
//
//  Copyright 2025 Peking University, ShenZhen. All rights reserved
//
//  Project Directors : Prof. Lining Zhang, Prof. Ru Huang
//  Authors           : Baokang Peng, Guoyao Cheng, Wu Dai,
//                      Fangxing Zhang, Yu Li, Honglin Wu
//
//  Notes:
//    - GAA global model (Lg: 16-100 nm; WGAA: 10-40 nm).
//    - Current and capacitance merged.
//    - Derived from BSIM-CMG ver.111.2.1 with the fusion modeling
//      technique [B. Peng et al., "PHIMO-NN: Compact Modeling by
//      Fusing Device Physics and Neural Networks for One-Shot
//      Parameterization," IEEE TCAD].
//    - The Verilog-A code corresponds to the model's Python
//      implementation used for training and adopts a re-organized
//      structure for clarity.
//
/**********************************************************************/
// [中文注释] 引入 Verilog-A 标准物理常数定义。
`include "constants.vams"
// [中文注释] 引入 electrical 等端口 discipline 定义。
`include "disciplines.vams"

// [中文注释] 声明 HSPICE/Verilog-A 实例可见参数列表。
(* instance_parameter_list = {L, W, NF} *)
// [中文注释] 定义 PMOS LVT 器件模块，端口顺序为 D/G/S/B。
module pmos_lvt(D, G, S, B);
// [中文注释] 声明四个端口均为双向电学端口。
   inout D, G, S, B;
// [中文注释] 把端口绑定为 electrical 网络。
   electrical D, G, S, B;

// [中文注释] 参数 L：实例沟道长度入口，模型内部通过 Lg = L + XL 得到有效沟道长度。
parameter real L=1.6e-8;
// [中文注释] 参数 W：实例宽度入口；当前模型内部 WGAA = W，用作 GAA nanosheet 宽度。
parameter real W=3.5e-8;
// [中文注释] 参数 NF：并联倍数或 finger 数，用于缩放电流和电荷。
parameter real NF=1;

// [中文注释] 参数 U0：低场迁移率基准参数。
parameter real U0 = 3.0e-2;
// [中文注释] 参数 XL：沟道长度偏移量，用于从版图长度修正到模型有效长度。
parameter real XL=1.2e-8;		
// [中文注释] 参数 DVTSHIFT：阈值电压整体平移项。
parameter real DVTSHIFT=0.0;		//###########1111
// [中文注释] 参数 DeltaWGAA：GAA 宽度偏差修正项。
parameter real DeltaWGAA = 0;
// [中文注释] 参数 DeltaTGAA：GAA 厚度偏差修正项。
parameter real DeltaTGAA = 0;
// [中文注释] 参数 EOT_0：等效氧化层厚度基准，后续会受 CV 神经网络输出修正。
parameter real EOT_0 = 1.1e-9;				//###########1111


// [中文注释] 以下参数用于把几何输入归一化到神经网络训练区间。
//*****network normalization factors******//
// [中文注释] 参数 tgaamax：NN 输入归一化使用的 TGAA 上界。
   real tgaamax = 5.0e-9;
// [中文注释] 参数 tgaamin：NN 输入归一化使用的 TGAA 下界。
   real tgaamin = 5.0e-9;
// [中文注释] 参数 wgaamax：NN 输入归一化使用的 WGAA 上界。
   real wgaamax = 4.0e-8;
// [中文注释] 参数 wgaamin：NN 输入归一化使用的 WGAA 下界。
   real wgaamin = 1.0e-8;
// [中文注释] 参数 lgaamax：NN 输入归一化使用的 Lg 上界。
   real lgaamax = 1e-7;
// [中文注释] 参数 lgaamin：NN 输入归一化使用的 Lg 下界。
   real lgaamin = 1.6e-8;
// [中文注释] 参数 netmax：NN 归一化目标区间上界。
	 real netmax  = 1.0; 
// [中文注释] 参数 netmin：NN 归一化目标区间下界。
	 real netmin  = -1.0; 




// [中文注释] 以下是训练后展开到 VA 源码中的神经网络权重和偏置；相似权重行按段注释，不逐个重复解释。
//*****input weight matrix******//
//******nnwa_b_c********************************************************************************************//
//******a means the number of hidden layers*****************************************************************//
//******b means the b th neurons of the a layer*************************************************************//
//******c measns the weight between the b th neurons of the a layer and the c of the previous layer ********//


