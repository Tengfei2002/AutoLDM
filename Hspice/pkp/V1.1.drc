GR_1_2_M9 {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID M9 10
}

GR_1_2_V9 {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID V9 10
}

GR_1_2_M10 {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID M10 10
}

GR_1_2_V10 {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID V10 10
}

GR_1_2_M11 {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID M11 10
}

GR_1_2_V11 {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID V11 10
}

GR_1_2_M12 {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID M12 10
}

GR_1_2_V12 {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID V12 10
}

GR_1_2_M13 {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID M13 10
}

GR_1_2_SVT_N {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID SVT_N 10
}

GR_1_2_SVT_P {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID SVT_P 10
}

GR_1_2_LVT_N {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID LVT_N 10
}

GR_1_2_LVT_P {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID LVT_P 10
}

GR_1_2_SLVT_N {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID SLVT_N 10
}

GR_1_2_SLVT_P {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID SLVT_P 10
}

GR_1_2_ACT {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID AA 10
}

GR_1_2_GATE {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID GT 10
}

GR_1_2_GCUT {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID GCUT 10
}

GR_1_2_VCT {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID VCT 10
}

GR_1_2_CT {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID CT 10
}

GR_1_2_VCG {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID VCG 10
}

GR_1_2_PIM {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID SP 10
}

GR_1_2_NIM {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID SN 10
}

GR_1_2_NW {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID NW 10
}

GR_1_2_NSH {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID NSH 10
}

GR_1_2_SDB {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID SDB 10
}

GR_1_2_CT_PR {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID CT_PR 10
}

GR_1_2_VCT_PR {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID VCT_PR 10
}

GR_1_2_M0_PR {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID M0_PR 10
}

GR_1_2_boundary {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID boundary 10
}

GR_3_4 {
@ Only shapes of geometry that are orthogonal or 45-degree angle are allowed
@ Shapes with acute angles between line segments are not allowed
    DRAWN SKEW
} 


// =======================================================
// ACT: Active Area design rules                           
// =======================================================  

GROUP GACT ACT_?

ACT_W_1 {    
@ minimum vertical width of ACT (outside the layer SRAMMRK) >= 15nm 
    err = INT [AA_h_edges] < 0.015 ABUT<90 OPPOSITE
    err OUTSIDE EDGE SRAMMRK
}

ACT_W_2_SRAM {    
@ minimum vertical width of ACT (interacting with the layer SRAMMRK) >= 10nm 
    err = INT [AA_h_edges] < 0.01 ABUT<90 OPPOSITE
    err NOT OUTSIDE EDGE SRAMMRK
}

ACT_W_3 {    
@ minimum horizontal width of ACT >= 15nm 
    INT AA_v_edges < 0.015 ABUT<90 OPPOSITE
}

ACT_W_4 {    
@ width in GATE poly direction  <= 50nm 
    INT (AA_h_edges) <= 0.050 ABUT<90 OPPOSITE
}

ACT_S_1 {
@ Minimum vertical spacing of ACT (outside the layer SRAMMRK) >= 60nm
    err = EXT [AA_h_edges] < 0.06 ABUT<90 OPPOSITE
    err OUTSIDE EDGE SRAMMRK

    EXT AA < 0.001 ABUT<90 SINGULAR REGION
} 

ACT_S_2_SRAM {
@ Minimum vertical spacing of ACT (interacting with the layer SRAMMRK) >= 40nm
    err = EXT [AA_h_edges] < 0.04 ABUT<90 OPPOSITE
    err NOT OUTSIDE EDGE SRAMMRK

    EXT AA < 0.001 ABUT<90 SINGULAR REGION
} 

ACT_S_2A {
@ Minimum horizontal spacing between ACT layers from source/drain regions(of different transistors) on different nets >= 48nm
    (EXT [AAi] < 0.048 ABUT<90 NOT CONNECTED) COIN EDGE AA_v_edges 
} 

ACT_S_2B {
@ Minimum horizontal spacing of ACT >= 16nm
    EXT AA_v_edges < 0.016 ABUT<90 OPPOSITE REGION
} 

ACT_S_3B {
@ Space between NW and ACT in GATE poly direction (outside the layer SRAMMRK) >= 27nm
    err = EXT AA_h_edges NW < 0.027 ABUT<90 OPPOSITE REGION MEASURE ALL
    err OUTSIDE SRAMMRK
} 

ACT_S_4B {
@ Space between NW and ACT in GATE poly direction (interacting with the layer SRAMMRK) >= 13.5nm
    err = EXT AA_h_edges NW < 0.0135 ABUT<90 OPPOSITE REGION MEASURE ALL
    err INTERACT SRAMMRK
} 

//ACT_EN_1A {
//@ ACT enclosure by NW >= 20nm
//    ENC (AA AND NW) NW < 0.020 ABUT<90 REGION
//} 

//ACT_AUX_1 {
//@ ACT must always be enclosed by NIM or PIM, such that no ACT layer edge(s) coincide with NIM or PIM
//    AA NOT INSIDE EDGE ALL_SN_SP
//} 

ACT_AUX_3 {
@ A notch in ACT along vertical axis is not allowed
    //AA_convex_90_270_edges COIN EDGE AA_h_edges
    AA_convex_270_270_edges COIN EDGE AA_v_edges
} 

ACT_A_1 {
@ ACT area (outside the layer SRAMMRK) >= 225nm2
    err = AREA AA < 0.000225  
    err OUTSIDE SRAMMRK
}

ACT_A_2_SRAM {
@ ACT area (interacting with the layer SRAMMRK) >= 150nm2
    err = AREA AA < 0.00015
    err INTERACT SRAMMRK
}

// =======================================================
// GATE: Gate design rules                           
// =======================================================  

GROUP GGATE GATE_?

GT_merge = SIZE GT BY 0.032 OVERUNDER
GT_merge_all = EXTENT GT

GATE_W_1 {
@ Horizontal GATE width >= 16nm
    INT (GT_v_edges) <= 0.016 ABUT<90 OPPOSITE
}

GATE_W_2 {    
@ Minimum vertical GATE width >= 40nm 
    INT GT_h_edges < 0.040 ABUT<90 OPPOSITE
}

GATE_S_1 {    
@ Exact horizontal GATE pitch (not cut by GCUT and not interacting with the layer SRAMMRK) == 48
    CHK_016_sides = INT [GT_v_edges] == 0.016 ABUT<90 OPPOSITE 
    err = (EXT (CHK_016_sides) == 0.048-0.016 ABUT<90 OPPOSITE) NOT COIN EDGE GT_merge
    err OUTSIDE EDGE (OR GCUT SRAMMRK)
}

GATE_S_2 {    
@ Minimum horizontal GATE spacing >= 32nm
    EXT GT_V_edges < 0.032 ABUT<90 OPPOSITE    
}

GATE_AUX_1 {
@ GATE not be bend
    NOT RECTANGLE GT ORTHOGONAL ONLY
} 

GATE_AUX_2 {
@ GATE may not be discontinuous along the vertical axis. Use GCUT layer to mark cuts in the GATE
    EXT GT_h_edges > 0 < 100 ABUT<90 OPPOSITE
} 

GATE_AA_AUX_3 {
@ AA layer vertical edge may not lie inside, or coincide with, the GATE layer
    AA_v_edges NOT OUTSIDE EDGE GT
} 

GATE_AA_EX_1 {
@ Minimum vertical extension of GATE (not cut by GCUT) past AA >= 5nm
    ENC GATE_LE [GT_0_h_edges] < 0.005 ABUT<90 OPPOSITE 
} 

GATE_AA_EX_2 {
@ Minimum horizontal extension of AA interacting with GATE (not cut by GCUT layer) past GATE (not cut by GCUT layer) >= 16nm
    chk_side = ANGLE (AA INTERACT GT_0) == 90
    ENC GATE_WE [chk_side] < 0.016 ABUT<90 OPPOSITE
} 

GATE_A_1 {
@ GATE area >= 640nm2
    AREA GT < 0.000640  
} 


// =======================================================
// NS: NANOSHEET design rules                           
// =======================================================  

GROUP GNS NS_?

NS_merge = SIZE NSH BY 0.1 OVERUNDER

NS_W_1 {
@ Vertical nanosheet width >= 10nm
    INT NS_h_edges < 0.010 ABUT<90 OPPOSITE
} 

NS_W_2 {
@ Minimum horizontal nanosheet width >= 90nm
    INT NS_V_edges < 0.090 ABUT<90 OPPOSITE
} 

NS_S_2 {
@ Exact vertical nanosheet spacing == 20nm
    (EXT (NS_h_edges) == 0.02 ABUT<90 OPPOSITE) NOT COIN EDGE NS_merge
    EXT NSH < 0.001 ABUT<90 SINGULAR
} 

NS_AUX_1 {
@ nanosheet may not be bend
    NOT RECTANGLE NSH ORTHOGONAL ONLY
} 


// =======================================================
// NW: Nwell design rules                           
// =======================================================  

GROUP GNW NW_?

NW_W_1 {
@ Minimum horizontal width of WELL >= 90nm
    INT NW_v_edges < 0.090 ABUT<90 OPPOSITE
} 

NW_W_2 {
@ Minimum vertical width of WELL >= 57nm
    INT NW_h_edges < 0.057 ABUT<90 OPPOSITE
} 

NW_S_1 {
@ Minimum vertical spacing between WELL layer polygons >= 90nm
    EXT NW_h_edges < 0.09 ABUT<90 OPPOSITE    
    EXT NW < 0.001 ABUT<90 SINGULAR REGION
} 

NW_S_2 {
@ Minimum horizontal spacing between WELL layer polygons >= 45nm
    EXT NW_v_edges < 0.045 ABUT<90 OPPOSITE
} 

NW_A_1A {
@ Minimum area of WELL >= 5130nm2
    AREA NW < 0.005130  
} 

NW_A_1B {
@ Minimum enclosed area of WELL >= 5130nm2
    AREA ((HOLES NW INNER) NOT NW) < 0.005130  
} 

NW_GATE_EX_1 {
@ Minimum horizontal extension of WELL past GATE (not cut by GCUT layer) >= 7nm
    ENC GT_v_edges NW < 0.007 ABUT<90 OPPOSITE
} 

//NW_GATE_EX_2 {
//@ Minimum vertical extension of WELL past GATE (not cut by GCUT layer) >= 7nm
//    ENC GT_h_edges NW < 0.007 ABUT<90 OPPOSITE
//} 


// =======================================================
// NIM: N-type Implant design rules                           
// =======================================================  

GROUP GNIM NIM_?

NIM_W_1 {
@ Minimum horizontal width of NIM >= 48nm
    INT SN_v_edges < 0.048 ABUT<90 OPPOSITE REGION
} 

NIM_W_2 {
@ Minimum vertical width of NIM (outside the layer SRAMMRK) >= 57nm
    err = INT SN_h_edges < 0.057 ABUT<90 OPPOSITE REGION
    err OUTSIDE SRAMMRK
} 

NIM_W_3_SRAM {
@ Minimum vertical width of NIM (interacting with the layer SRAMMRK) >= 45nm
    err = INT SN_h_edges < 0.045 ABUT<90 OPPOSITE REGION
    err INTERACT SRAMMRK
} 

NIM_S_1 {
@ NIM horizontal Space >= 48nm
    EXT SN_v_edges < 0.048 ABUT<90 OPPOSITE REGION
    EXT SN < 0.001 ABUT<90 SINGULAR REGION
} 

NIM_S_2 {
@ horizontal Space between ACT and NIM >= 48nm
    EXT AA SN_v_edges < 0.048 ABUT<90 OPPOSITE REGION
} 

//NIM_EN_1 {
//@ NIM enclosure of ACT >= 10nm
//    ENC NAA SN < 0.010 ABUT<90 REGION
//} 

NIM_R_1 {
@ NIM AND PIM may not overlap
    SN AND SP
} 

NIM_A_1 {
@ NIM area >= 2736nm2
    AREA SN < 0.002736
} 


// =======================================================
// PIM: P-type Implant design rules                           
// =======================================================  

GROUP GPIM PIM_?

PIM_W_1 {
@ Minimum horizontal width of PIM >= 48nm
    INT SP_v_edges < 0.048 ABUT<90 OPPOSITE REGION
} 

PIM_W_2 {
@ Minimum vertical width of PIM (outside the layer SRAMMRK) >= 57nm
    err = INT SP_h_edges < 0.057 ABUT<90 OPPOSITE REGION
    err OUTSIDE SRAMMRK
} 

PIM_W_3_SRAM {
@ Minimum vertical width of PIM (interacting with the layer SRAMMRK) >= 45nm
    err = INT SP_h_edges < 0.045 ABUT<90 OPPOSITE REGION
    err INTERACT SRAMMRK
} 

PIM_S_1 {
@ PIM horizontal Space >= 48nm
    EXT SP_v_edges < 0.048 ABUT<90 OPPOSITE REGION
    EXT SP < 0.001 ABUT<90 SINGULAR REGION
} 

PIM_S_2 {
@ horizontal Space between ACT and PIM >= 48nm
    EXT AA SP_v_edges < 0.048 ABUT<90 OPPOSITE REGION
} 

//PIM_EN_1 {
//@ PIM enclosure of AA >= 10nm
//    ENC PAA SP < 0.010 ABUT<90 REGION
//} 

PIM_A_1 {
@ PIM area >= 2736nm2
    AREA SP < 0.002736
} 


// =======================================================
// VT: N/P-type Vt MOS design rules                           
// =======================================================  

VT_AUX_2{
@ VT layers (LVT, SLVT, and SVT) may not overlap
    LVT_N AND (OR LVT_P SVT_N SVT_P SLVT_N SLVT_P) 
    LVT_P AND (OR LVT_N SVT_N SVT_P SLVT_N SLVT_P) 
    SLVT_N AND (OR LVT_P SVT_N SVT_P LVT_N SLVT_P) 
    SLVT_P AND (OR LVT_N SVT_N SVT_P SLVT_N LVT_P) 
    SVT_N AND (OR LVT_P LVT_N SVT_P SLVT_N SLVT_P) 
    SVT_P AND (OR LVT_N SVT_N LVT_P SLVT_N SLVT_P) 
}


// =======================================================
// CT: CT design rules                           
// =======================================================  

GROUP GCT CT_?

CT_AA = CT AND AA
CT_AA_h_edges = ANGLE CT_AA == 0 
CT_AA_v_edges = ANGLE CT_AA == 90   

CT_VCT = CT AND VCT
CT_VCT_h_edges = ANGLE CT_VCT == 0 
CT_VCT_v_edges = ANGLE CT_VCT == 90  

CT_W_1 {
@ Minimum horizontal width of CT >= 10nm
    INT CT_v_edges < 0.01 ABUT<90 OPPOSITE REGION
} 

CT_W_2 {
@ Minimum vertical width of CT (outside the layer SRAMMRK) >= 20nm
    err = INT CT_h_edges < 0.02 ABUT<90 OPPOSITE REGION
    err OUTSIDE SRAMMRK
} 

CT_W_3_SRAM {
@ Minimum vertical width of CT (interacting with the layer SRAMMRK) >= 15nm
    err = INT CT_h_edges < 0.015 ABUT<90 OPPOSITE REGION
    err INTERACT SRAMMRK
} 

CT_S_1 {
@ Minimum horizontal spacing between two CT layer polygons >= 28nm
    EXT CT_v_edges < 0.028 ABUT<90 OPPOSITE REGION
    EXT CT < 0.001 ABUT<90 SINGULAR REGION
} 

CT_GATE_S_2 {
@ Minimum horizontal spacing between CT and GATE >= 6nm
    EXT CT_v_edges GT < 0.006 ABUT<90 OPPOSITE REGION
} 

CT_ACTIVE_OV_1 {
@ Minimum vertical overlap between CT and ACTIVE (outside the layer SRAMMRK) >= 15nm
    err = INT CT_AA_h_edges < 0.015 ABUT<90 OPPOSITE REGION
    err NOT SRAMMRK
} 

CT_ACTIVE_OV_2_SRAM {
@ Minimum vertical overlap between CT and ACTIVE (interacting with the layer SRAMMRK) >= 10nm
    err = INT CT_AA_h_edges < 0.01 ABUT<90 OPPOSITE REGION
    err INTERACT SRAMMRK
} 

CT_VCT_OV_2 {
@ Minimum vertical overlap between CT and VCT >= 15nm
    INT CT_VCT_h_edges < 0.015 ABUT<90 OPPOSITE REGION
} 

CT_GATE_AUX_1 {
@ CT and GATE may not overlap or touch
    CT INTERACT GT
} 

CT_ACT_AUX_3 {
@ CT may not be entirely outside ACT
    CT OUTSIDE AA
} 

CT_ACT_EX_1 {
@ Minimum vertical extension of CT past ACT >= 8nm
    ENC AA_h_edges CT_h_edges < 0.008 ABUT<90 OPPOSITE REGION

    CT_h_edges INSIDE EDGE AA
}

// =======================================================
// GCUT: GATE cut design rules                           
// =======================================================  

GROUP GGCUT GCUT_?

GCUT_GT = GCUT AND GT

GCUT_GT_h_edges = ANGLE GCUT_GT == 0 
GCUT_GT_v_edges = ANGLE GCUT_GT == 90   

GCUT_W_1 {
@ Minimum vertical width of GCUT >= 20nm
    INT GCUT_h_edges < 0.020 ABUT<90 OPPOSITE REGION
} 

GCUT_W_2 {
@ Maximum vertical width  <= 40nm
    INT (GCUT_h_edges) <= 0.04 ABUT<90 OPPOSITE EXCLUDE SHIELDED
} 

GCUT_L_1 {
@ GCUT edge length in S/D direction >= 35nm
    LENGTH GCUT_h_edges < 0.035
} 

GCUT_ACTIVE_S_1 {
@ Minimum vertical spacing between GCUT and channel >= 5nm
    EXT GCUT_h_edges GATE_LE < 0.005 ABUT<90 OPPOSITE REGION
} 

GCUT_GATE_EX_1 {
@ Minimum horizontal extension of GCUT past GATE >= 16nm
    ENC GT GCUT_v_edges < 0.016 ABUT<90 OPPOSITE REGION
} 

GCUT_GATE_S_2 {
@ Minimum spacing of GCUT to GATE, when the former is not being used to cut a particular polygon drawn using the latter >= 16nm
    EXT GT GCUT < 0.016 ABUT<90 SINGULAR REGION
} 

GCUT_S_3 {
@ Minimum vertical spacing between two GCUT layer polygons >= 40nm
    EXT GCUT_h_edges < 0.04 ABUT<90 OPPOSITE REGION
} 

GCUT_O_1 {
@ Overlap of GATE and GCUT in GATE poly direction >= 5nm
    INT GCUT_GT_h_edges < 0.005 ABUT<90 OPPOSITE REGION
} 

GCUT_AUX_1 {
@ GCUT layer may not exist without the layer GATE.
    GCUT OUTSIDE GT
} 

GCUT_AUX_2 {
@ GCUT layer vertical edge may not lie inside, or coincide with, the GATE layer
    GCUT_v_edges NOT OUTSIDE EDGE GT
} 

GCUT_AUX_3 {
@ GCUT may not interact with channel.
    GCUT INTERACT GATE
} 


// =======================================================
// CT_PR: CT powerrail design rules                           
// =======================================================  

GROUP GCT_PR CT_PR_?

CT_PR_AA = CT_PR AND AA
CT_PR_AA_h_edges = ANGLE CT_PR_AA == 0 
CT_PR_AA_v_edges = ANGLE CT_PR_AA == 90   

CT_PR_VCT_PR = CT_PR AND VCT_PR
CT_PR_VCT_PR_h_edges = ANGLE CT_PR_VCT_PR == 0 
CT_PR_VCT_PR_v_edges = ANGLE CT_PR_VCT_PR == 90  

CT_PR_W_1 {
@ Minimum horizontal width of CT_PR >= 10nm
    INT CT_PR_v_edges < 0.01 ABUT<90 OPPOSITE REGION
} 

CT_PR_W_2 {
@ Minimum vertical width of CT_PR >= 60nm
    INT CT_PR_h_edges < 0.06 ABUT<90 OPPOSITE REGION
} 

CT_PR_S_1 {
@ Minimum horizontal spacing between two CT_PR layer polygons >= 48nm
    EXT CT_PR_v_edges < 0.048 ABUT<90 OPPOSITE REGION 
    EXT CT_PR < 0.001 ABUT<90 SINGULAR REGION
} 

CT_PR_GATE_S_2 {
@ Minimum horizontal spacing between CT_PR and GATE >= 6nm
    EXT CT_PR GT < 0.006 ABUT<90 SINGULAR REGION
} 

CT_PR_ACTIVE_OV_1 {
@ Minimum vertical overlap between CT_PR and ACTIVE >= 20nm
    INT CT_PR_AA_h_edges < 0.02 ABUT<90 OPPOSITE REGION
} 

CT_PR_VCT_PR_OV_2 {
@ Minimum vertical overlap between CT_PR and VCT_PR >= 15nm
    INT CT_PR_VCT_PR_h_edges < 0.015 ABUT<90 OPPOSITE REGION
} 

CT_PR_GATE_AUX_1 {
@ CT_PR and GATE may not overlap or touch
    CT_PR INTERACT GT
} 

CT_PR_ACT_AUX_3 {
@ CT_PR may not be entirely outside ACT
    CT_PR OUTSIDE AA
} 


// =======================================================
// VCT: VCT design rules                           
// =======================================================  

GROUP GVCT VCT_?

VCT_0.005_M0_end_cap = ENC VCT M0_v_edges == 0.005 ABUT<90 OPPOSITE REGION 

vct_with_end_cap = VCT TOUCH VCT_0.005_M0_end_cap == 2
vct_without_end_cap = VCT NOT vct_with_end_cap

VCT_M0 = VCT INTERACT M0
VCT_M0_h_edges = ANGLE VCT_M0 == 0
VCT_M0_v_edges = ANGLE VCT_M0 == 90

VCT_W_1 {
@ Minimum width of a VCT instance along the length of M0 >= 10nm
    INT VCT_v_edges < 0.01 ABUT<90 OPPOSITE REGION  // VCT have same width with M0
} 

VCT_S_1 {
@ Minimum spacing between VCT instances [on the same M0 track | on parallel M0 tracks, if they are not aligned with each other | on parallel M0 tracks, if they are fully or partially aligned with each other]] >= 20nm
    EXT VCT < 0.020 ABUT<90 SINGULAR OPPOSITE REGION
} 

VCT_S_2 {
@ Minimum corner-to-corner spacing between two VCT instances—both with a 5 nm M0 end-cap >= 23nm
    EXT vct_with_end_cap < 0.023 CORNER TO CORNER REGION
} 

VCT_S_3 {
@ Minimum corner-to-corner spacing between two VCT instances—both without a 5 nm M0 end-cap >= 30nm
    EXT vct_without_end_cap < 0.03 CORNER TO CORNER REGION
} 

VCT_S_4 {
@ Minimum corner-to-corner spacing between two VCT instances—one with and another without, a 5 nm M0 end-cap >= 27nm
    EXT vct_without_end_cap vct_with_end_cap < 0.027 CORNER TO CORNER REGION
} 

VCT_CT_EN_1 {
@ Minimum enclosure of VCT by CT on two opposite sides(outside the layer SRAMMRK) >= 3.5nm
    ENC (VCT OUTSIDE SRAMMRK) CT_h_edges < 0.0035 ABUT<90 OPPOSITE REGION

    VCT NOT CT
} 

VCT_M0_EN_1 {
@ Minimum enclosure of VCT by M0 on two opposite sides(outside the layer SRAMMRK) >= 4nm
    ENC (VCT OUTSIDE SRAMMRK) M0_v_edges < 0.004 ABUT<90 OPPOSITE REGION

    VCT NOT M0
} 

VCT_AUX_1 {
@ VCT must always interact with M0 and CT
    VCT OUTSIDE M0
    VCT OUTSIDE CT
} 

VCT_M0_AUX_3 {
@ VCT must exactly be the same width as M0 along the  horizontal direction
    NOT COIN EDGE VCT_M0_h_edges M0
} 


// =======================================================
// VCT_PR: VCT_PR  design rules                           
// =======================================================  

GROUP GVCT_PR VCT_PR_?

VCT_PR_0.005_M0_PR_end_cap = ENC VCT_PR M0_PR_v_edges == 0.005 ABUT<90 OPPOSITE REGION 
vct_pr_with_end_cap = VCT_PR TOUCH VCT_PR_0.005_M0_PR_end_cap == 2
vct_pr_without_end_cap = VCT_PR NOT vct_pr_with_end_cap

VCT_PR_M0_PR = VCT_PR INTERACT M0_PR
VCT_PR_M0_PR_h_edges = ANGLE VCT_PR_M0_PR == 0
VCT_PR_M0_PR_v_edges = ANGLE VCT_PR_M0_PR == 90

VCT_PR_W_1 {
@ Minimum width of a VCT_PR instance along the length of M0_PR >= 19nm
    INT VCT_PR_v_edges < 0.019 ABUT<90 OPPOSITE REGION  // VCT_PR have same width with M0
} 

VCT_PR_S_1 {
@ Minimum spacing between VCT_PR instances >= 48nm
    EXT VCT_PR < 0.048 ABUT<90 OPPOSITE REGION
} 

VCT_PR_S_2 {
@ Minimum corner-to-corner spacing between two VCT_PR instances—both with a 5 nm M0_PR end-cap >= 23nm
    EXT vct_pr_with_end_cap < 0.023 CORNER TO CORNER REGION
} 

VCT_PR_S_3 {
@ Minimum corner-to-corner spacing between two VCT_PR instances—both without a 5 nm M0_PR end-cap >= 30nm
    EXT vct_pr_without_end_cap < 0.03 CORNER TO CORNER REGION
} 

VCT_PR_S_4 {
@ Minimum corner-to-corner spacing between two VCT_PR instances—one with and another without, a 5 nm M0_PR end-cap >= 27nm
    EXT vct_pr_without_end_cap vct_pr_with_end_cap < 0.027 CORNER TO CORNER REGION
} 

//VCT_PR_CT_PR_EN_1 {
//@ Minimum enclosure of VCT_PR by CT_PR on two opposite sides >= 3.5nm
//    ENC VCT_PR CT_PR_h_edges < 0.0035 ABUT<90 REGION
//
//    VCT_PR NOT CT_PR
//} 

VCT_PR_M0_PR_EN_1 {
@ Minimum enclosure of VCT_PR by M0_PR on two opposite sides >= 4nm
    ENC VCT_PR M0_PR_v_edges < 0.004 ABUT<90 REGION

    VCT_PR NOT M0_PR
} 

VCT_PR_AUX_1 {
@ VCT_PR must always interact with M0_PR and CT_PR
    VCT_PR OUTSIDE M0_PR 
    VCT_PR OUTSIDE CT_PR
} 

VCT_PR_M0_PR_AUX_3 {
@ VCT_PR must exactly be the same width as M0_PR along the  horizontal direction
    NOT COIN EDGE VCT_PR_M0_PR_h_edges M0_PR
} 


// =======================================================
// VCG: VCG design rules                           
// =======================================================  

GROUP GVCG VCG_?

VCG_W_1 {
@ Minimum width of VCG >= 14nm
    INT VCG < 0.014 ABUT<90 SINGULAR REGION
} 

//VCG_S_1 {
//@ Minimum (side-to-side) spacing between two VCG layer polygons' edges, when both edges are > 36 nm.  >= 10nm
//    vcg_meet_wid_sides = INT (VCG) <= 0.036 ABUT<90 OPPOSITE
//    vcg_meet_wid_block = VCG WITH EDGE vcg_meet_wid_sides
//    EXT vcg_meet_wid_block < 0.01 OPPOSITE REGION
//
//    EXT VCG < 0.001 ABUT<90 SINGULAR REGION
//} 

VCG_GATE_S_1 {
@ Minimum horizontal spacing between VCG and GATE (not cut using GCUT) layer polygons >= 30nm
    EXT VCG_v_edges GT_0 < 0.03 ABUT<90 OPPOSITE REGION MEASURE ALL
} 

VCG_GATE_EN_1 {
@ Minimum enclosure of VCG by GATE on two opposite sides >= 1nm
    ENC VCG GT_h_edges < 0.001 ABUT<90 REGION

    VCG NOT GT
} 

VCG_M0_EN_1 {
@ Minimum enclosure of VCG by M0 on two opposite sides >= 4nm
    ENC VCG M0_v_edges < 0.004 ABUT<90 REGION

    VCG NOT M0
} 

VCG_VCT_S_1 {
@ Minimum corner-to-corner spacing between VCG and VCT >= 15nm
    EXT VCG VCT < 0.015  ABUT<90 CORNER TO CORNER SINGULAR REGION
} 

VCG_AUX_1 {
@ VCG must always interact with M0 and GATE
    VCG OUTSIDE M0
    VCG OUTSIDE GT
} 

VCG_M0_AUX_1 {
@ VCG must exactly be the same width as M0 along the direction perpendicular to the M0 length
    VCG WITH EDGE (VCG_h_edges NOT COIN INSIDE EDGE M0)
} 


// =======================================================
// M0: M0 design rules                           
// =======================================================  

GROUP GM0 M0_?

M0_W_1 {
@ Minimum vertical width of M0 >= 15nm
    INT M0_h_edges < 0.015 ABUT<90 OPPOSITE REGION
}

M0_W_2 {
@ Minimum horizontal width of M0,except MARKS region >= 25nm
    INT M0_v_edges < 0.025 ABUT<90 OPPOSITE REGION
}

M0_S_1 {
@ Minimum vertical spacing of M0s, >= 11nm
    EXT M0_h_edges < 0.011 ABUT<90 REGION
}

M0_M0_PR_S_1 {
@ Minimum vertical spacing between M0 and M0_PR >= 11nm
    EXT M0_h_edges M0_PR_h_edges < 0.011 ABUT<90 REGION
}

M0_S_2 {
@ Minimum horizontal(TtT) spacing between two M0 layers on the same track >= 18nm
    EXT M0_v_edges < 0.017 ABUT<90 OPPOSITE REGION
}

M0_A_1 {
@ Area of M0 >= 375nm2
    AREA M0 < 0.000375  
}

M0_S_3 {
@ Minimum corner-to-corner spacing between two M0 polygons >= 15nm
    EXT M0 < 0.015 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

M0_AUX_1 {
@ M0 must not bend
    NOT RECTANGLE M0 ORTHOGONAL ONLY
}

//M0_EX_1 {
//@ ACT extension outside of M0 in S/D direction >= 5nm
//    ENC (M0 AND AA) [AA_v_edges] < 0.005 ABUT<90 OPPOSITE 
//}


// =======================================================
// M0_PR: M0_PR design rules                           
// =======================================================  

GROUP GM0_PR M0_PR_?

M0_PR_W_1 {
@ Minimum vertical width of M0_PR >= 38nm
    INT M0_PR_h_edges < 0.038 ABUT<90 OPPOSITE REGION
}

M0_PR_W_2 {
@ Minimum horizontal width of M0_PR, except MARKS region >= 90nm
    INT M0_PR_v_edges < 0.09 ABUT<90 OPPOSITE REGION
}

M0_PR_S_1 {
@ Minimum vertical spacing of M0_PRs, >= 98nm
    EXT M0_PR_h_edges < 0.098 ABUT<90 REGION
}

M0_PR_S_2 {
@ Minimum horizontal(TtT) spacing two M0_PR layers on the same track >= 60nm
    EXT M0_PR_v_edges < 0.06 ABUT<90 OPPOSITE REGION
}

M0_PR_S_3 {
@ Minimum corner-to-corner spacing between two M0_PR polygons >= 50nm
    EXT M0_PR < 0.05 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

M0_PR_AUX_1 {
@ M0_PR must not bend
    NOT RECTANGLE M0_PR ORTHOGONAL ONLY
}

M0_PR_A_1 {
@ Area of M0_PR >= 1710nm2
    AREA M0_PR < 0.001710
}


// =======================================================
// V0: V0 design rules                           
// =======================================================  

GROUP GV0 V0_?

V0_M0 = V0 INTERACT M0
V0_M0_h_edges = ANGLE V0_M0 == 0
V0_M0_v_edges = ANGLE V0_M0 == 90

V0_M0_PR = V0 INTERACT M0_PR
V0_M0_PR_h_edges = ANGLE V0_M0_PR == 0
V0_M0_PR_v_edges = ANGLE V0_M0_PR == 90

V0_M1 = V0 INTERACT M1
V0_M1_h_edges = ANGLE V0_M1 == 0
V0_M1_v_edges = ANGLE V0_M1 == 90


V0_W_1 {
@ Minimum width of V0 >= 15nm
    INT V0 < 0.015 ABUT<90 SINGULAR REGION
}

//V0_S_1 {
//@ Minimum spacing between V0 instances [on the same M1 track | on parallel M1 tracks, if they are not aligned with each other | on parallel M1 tracks, if they are fully or partially aligned with each other] >= [9 | 23 | 14]nm
//    EXT V0 < 0.009 ABUT<90 OPPOSITE REGION
//
//    EXT V0_h_edges < 0.014 ABUT<90 OPPOSITE REGION
//
//    opposite_region = EXT V0_h_edges >= 0.014 < 0.023 ABUT<90 OPPOSITE REGION
//    opposite_region_h_edges = ANGLE opposite_region == 0
//    opposite_region_v_edges = ANGLE opposite_region == 90
//
//    chk = EXPAND EDGE opposite_region_h_edges OUTSIDE BY 0.001
//    chk_h_sides = ANGLE chk == 0
//    good3 = DFM PROPERTY chk V0_h_edges chk_h_sides OVERLAP ABUT ALSO MULTI [-= LENGTH(V0_h_edges)/COUNT(V0_h_edges) - LENGTH(chk_h_sides)/COUNT(chk_h_sides)] == 0
//    opposite_region NOT (opposite_region INTERACT good3)
//}

V0_S_1 {
@ Minimum corner to corner spacing between V0 instances >= 14nm
    EXT V0 < 0.014 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

V0_M0_EN_1 {
@ V0 must be covered by M0 or M0_PR
    V0 NOT (M0 OR M0_PR)
}

V0_M0_EN_2 {
@ V0 enclosure by M0 or M0_PR on horizontal direction >= 5nm
    ENC V0 [M0_v_edges] < 0.005 ABUT<90 OPPOSITE INSIDE ALSO
    ENC V0 [M0_PR_v_edges] < 0.005 ABUT<90 OPPOSITE INSIDE ALSO
}

V0_M0_AUX_1 {
@ V0 must exactly be the same vertical width with M0/M0_PR
    NOT COIN EDGE V0_M0_h_edges M0
    NOT COIN EDGE V0_M0_PR_h_edges M0_PR
}

V0_M1_AUX_2 {
@ V0 must exactly be the same horizontal width with M1
    NOT COIN EDGE V0_M1_v_edges M1
}

V0_AUX_3 {
@ V0 must interact with M0/M0_PR and M1
    (V0 NOT (OR M0 M0_PR)) OR (V0 NOT M1)
}

V0_M1_EN_1 {
@ V0 enclosure by M1 on two opposite sides >= 5nm
    ENC V0_h_edges M1 < 0.005 ABUT<90 OPPOSITE REGION
}


// =======================================================
// M1: M1 design rules                           
// =======================================================  

GROUP GM1 M1_?

M1_W_1 {
@ Minimum vertical width of M1 >= 28nm
    INT M1_h_edges < 0.028 ABUT<90 OPPOSITE REGION
}

M1_W_2 {
@ Minimum horizontal width of M1 >= 21nm
    INT M1_v_edges < 0.021 ABUT<90 OPPOSITE REGION
}

M1_S_1 {
@ Minimum horizontal spacing of M1s, >= 13nm
    EXT M1_v_edges < 0.013 ABUT<90 REGION
}

M1_S_2 {
@ Minimum vertical(TtT) spacing between two M1 layers on the same track >= 27nm
    EXT M1_h_edges < 0.027 ABUT<90 OPPOSITE REGION
}

M1_A_1 {
@ Area of M1 >= 504nm2
    AREA M1 < 0.000504  
}

M1_S_3 {
@ Minimum corner-to-corner spacing between two M1 polygons >= 24nm
    EXT M1 < 0.024 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

M1_AUX_1 {
@ M1 must not bend
    NOT RECTANGLE M1 ORTHOGONAL ONLY
}


// =======================================================
// V1: V1 design rules                           
// =======================================================  

GROUP GV1 V1_?

V1_M1 = V1 INTERACT M1
V1_M1_h_edges = ANGLE V1_M1 == 0
V1_M1_v_edges = ANGLE V1_M1 == 90

V1_M2 = V1 INTERACT M2
V1_M2_h_edges = ANGLE V1_M2 == 0
V1_M2_v_edges = ANGLE V1_M2 == 90


V1_W_1 {
@ Minimum width >= 21nm
    INT V1 < 0.021 ABUT<90 SINGULAR REGION
}

V1_S_1 {
@ Minimum corner to corner spacing between V1 instances >= 15nm
    EXT V1 < 0.015 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

V1_M1_AUX_1 {
@ V1 must exactly be the same horizontal width with M1
    NOT COIN EDGE V1_M1_v_edges M1
}

V1_M2_AUX_2 {
@ V1 must exactly be the same vertical width with M2
    NOT COIN EDGE V1_M2_h_edges M2
}

V1_AUX_3 {
@ V1 must interact with M1 and M2
    (V1 NOT M1) OR (V1 NOT M2)
}

V1_M1_EN_2 {
@ V1 enclosure by M1 >= 5nm
    ENC V1_h_edges M1 < 0.005 ABUT<90 OPPOSITE REGION
}

V1_M2_EN_1 {
@ V1 enclosure by M2 >= 5nm
    ENC V1_v_edges M2 < 0.005 ABUT<90 OPPOSITE REGION
}


// =======================================================
// M2: M2 design rules                           
// =======================================================  

GROUP GM2 M2_?

M2_W_1 {
@ Minimum Vertical width >= 21nm
    INT M2_h_edges < 0.021 ABUT<90 REGION
}

M2_S_1 {
@ Minimum Vertical spacing >= 13nm
    EXT M2_h_edges < 0.013 ABUT<90 REGION
}

M2_S_2 {
@ Minimum Horizontal(TtT) spacing between two M2 layers on the same track >= 20nm
    EXT M2_v_edges < 0.02 ABUT<90 OPPOSITE REGION
}

M2_S_3 {
@ Minimum corner-to-corner spacing between two M2 polygons >= 16nm
    EXT M2 < 0.016 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

M2_AUX_1 {
@ M2 must not bend
    NOT RECTANGLE M2 ORTHOGONAL ONLY
}


// =======================================================
// V2: V2 design rules                           
// =======================================================  

GROUP GV2 V2_?

V2_M2 = V2 INTERACT M2
V2_M2_h_edges = ANGLE V2_M2 == 0
V2_M2_v_edges = ANGLE V2_M2 == 90

V2_M3 = V2 INTERACT M3
V2_M3_h_edges = ANGLE V2_M3 == 0
V2_M3_v_edges = ANGLE V2_M3 == 90


V2_W_1 {
@ Minimum width >= 21nm
    INT V2 < 0.021 ABUT<90 SINGULAR REGION
}

V2_S_1 {
@ Minimum corner to corner spacing between V2 instances>= 15nm
    EXT V2 < 0.015 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

V2_M2_AUX_1 {
@ V2 must exactly be the same vertical width with M2
    NOT COIN EDGE V2_M2_h_edges M2
}

V2_M3_AUX_2 {
@ V2 must exactly be the same Horizontal width with M3
    NOT COIN EDGE V2_M3_v_edges M3
}

V2_AUX_3 {
@ V2 must interact with M2 and M3
    (V2 NOT M2) OR (V2 NOT M3)
}

V2_M2_EN_2 {
@ V2 enclosure by M2 >= 5nm
    ENC V2_v_edges M2 < 0.005 ABUT<90 OPPOSITE REGION
}

V2_M3_EN_1 {
@ V2 enclosure by M3 >= 5nm
    ENC V2_h_edges M3 < 0.005 ABUT<90 OPPOSITE REGION
}


// =======================================================
// M3: M3 design rules                           
// =======================================================  

GROUP GM3 M3_?

M3_W_1 {
@ Minimum Horizontal width >= 21nm
    INT M3_v_edges < 0.021 ABUT<90 REGION
}

M3_S_1 {
@ Minimum Horizontal spacing >= 13nm
    EXT M3_v_edges < 0.013 ABUT<90 REGION
}

M3_S_2 {
@ Minimum Horizontal(TtT) spacing between two M3 layers on the same track >= 20nm
    EXT M3_v_edges < 0.02 ABUT<90 OPPOSITE REGION
}

M3_S_3 {
@ Minimum corner-to-corner spacing between two M3 polygons >= 16nm
    EXT M3 < 0.016 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

M3_AUX_1 {
@ M3 must not bend
    NOT RECTANGLE M3 ORTHOGONAL ONLY
}


// =======================================================
// V3: V3 design rules                           
// =======================================================  

GROUP GV3 V3_?

V3_M3 = V3 INTERACT M3
V3_M3_h_edges = ANGLE V3_M3 == 0
V3_M3_v_edges = ANGLE V3_M3 == 90

V3_M4 = V3 INTERACT M4
V3_M4_h_edges = ANGLE V3_M4 == 0
V3_M4_v_edges = ANGLE V3_M4 == 90

V3_W_1 {
@ Minimum width >= 21nm
    INT V3 < 0.021 ABUT<90 SINGULAR REGION
}

V3_S_1 {
@ Minimum corner to corner spacing between V3 instances>= 15nm
    EXT V3 < 0.015 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

V3_M3_AUX_1 {
@ V3 must exactly be the same horizontal width with M3
    NOT COIN EDGE V3_M3_v_edges M3
}

V3_M4_AUX_2 {
@ V3 must exactly be the same vertical width with M4
    NOT COIN EDGE V3_M4_h_edges M4
}

V3_AUX_3 {
@ V3 must interact with M3 and M4
    (V3 NOT M3) OR (V3 NOT M4)
}


V3_M3_EN_2 {
@ V3 enclosure by M3 >= 5nm
    ENC V3_h_edges M3 < 0.005 ABUT<90 OPPOSITE REGION
}

V3_M4_EN_1 {
@ V3 enclosure by M4 >= 5nm
    ENC V3_v_edges M4 < 0.005 ABUT<90 OPPOSITE REGION
}


// =======================================================
// M4: M4 design rules                           
// =======================================================  

GROUP GM4 M4_?

M4_W_1 {
@ Minimum Vertical width >= 30nm
    INT M4_h_edges < 0.030 ABUT<90 REGION
}

M4_S_1 {
@ Minimum Vertical spacing >= 25nm
    EXT M4_h_edges < 0.025 ABUT<90 REGION
}

M4_S_2 {
@ Minimum Horizontal(TtT) spacing between two M4 layers on the same track >= 32nm
    EXT M4_v_edges < 0.032 ABUT<90 OPPOSITE REGION
}

M4_S_3 {
@ Minimum corner-to-corner spacing between two M4 polygons >= 28nm
    EXT M4 < 0.028 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

M4_AUX_1 {
@ M4 must not bend
    NOT RECTANGLE M4 ORTHOGONAL ONLY
}


// =======================================================
// V4: V4 design rules                           
// =======================================================  

GROUP GV4 V4_?

V4_M4 = V4 INTERACT M4
V4_M4_h_edges = ANGLE V4_M4 == 0
V4_M4_v_edges = ANGLE V4_M4 == 90

V4_M5 = V4 INTERACT M5
V4_M5_h_edges = ANGLE V4_M5 == 0
V4_M5_v_edges = ANGLE V4_M5 == 90


V4_W_1 {
@ Minimum width >= 30nm
    INT V4 < 0.024 ABUT<90 SINGULAR REGION
}

V4_S_1 {
@ Minimum corner to corner spacing between V4 instances>= 25nm
    EXT V4 < 0.025 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

V4_M4_AUX_1 {
@ V4 must exactly be the same vertical width with M4
    NOT COIN EDGE V4_M4_h_edges M4
}

V4_M5_AUX_2 {
@ V4 must exactly be the same Horizontal width with M5
    NOT COIN EDGE V4_M5_v_edges M5
}

V4_AUX_3 {
@ V4 must interact with M4 and M5
    (V4 NOT M4) OR (V4 NOT M5)
}

V4_M4_EN_2 {
@ V4 enclosure by M4 >= 5nm
    ENC V4_v_edges M4 < 0.005 ABUT<90 OPPOSITE REGION
}

V4_M5_EN_1 {
@ V4 enclosure by M5 >= 5nm
    ENC V4_h_edges M5 < 0.005 ABUT<90 OPPOSITE REGION
}


// =======================================================
// M5: M5 design rules                           
// =======================================================  

GROUP GM5 M5_?

M5_W_1 {
@ Minimum Horizontal width >= 30nm
    INT M5_v_edges < 0.030 ABUT<90 REGION
}

M5_S_1 {
@ Minimum Horizontal spacing >= 25nm
    EXT M5_v_edges < 0.025 ABUT<90 REGION
}

M5_S_2 {
@ Minimum Horizontal(TtT) spacing between two M5 layers on the same track >= 32nm
    EXT M5_v_edges < 0.032 ABUT<90 OPPOSITE REGION
}

M5_S_3 {
@ Minimum corner-to-corner spacing between two M5 polygons >= 28nm
    EXT M5 < 0.028 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

M5_AUX_1 {
@ M5 must not bend
    NOT RECTANGLE M5 ORTHOGONAL ONLY
}


// =======================================================
// V5: V5 design rules                           
// =======================================================  

GROUP GV5 V5_?

V5_M5 = V5 INTERACT M5
V5_M5_h_edges = ANGLE V5_M5 == 0
V5_M5_v_edges = ANGLE V5_M5 == 90

V5_M6 = V5 INTERACT M6
V5_M6_h_edges = ANGLE V5_M6 == 0
V5_M6_v_edges = ANGLE V5_M6 == 90


V5_W_1 {
@ Minimum width >= 30nm
    INT V5 < 0.030 ABUT<90 SINGULAR REGION
}

V5_S_1 {
@ Minimum corner to corner spacing >= 25nm
    EXT V5 < 0.025 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

V5_M5_AUX_1 {
@ V5 must exactly be the same horizontal width with M5
    NOT COIN EDGE V5_M5_v_edges M5
}

V5_M6_AUX_2 {
@ V5 must exactly be the same vertical width with M6
    NOT COIN EDGE V5_M6_h_edges M6
}

V5_AUX_3 {
@ V5 must interact with M5 and M6
    (V5 NOT M5) OR (V5 NOT M6)
}

V5_M5_EN_2 {
@ V5 enclosure by M5 >= 5nm
    ENC V5_h_edges M5 < 0.005 ABUT<90 OPPOSITE REGION
}

V5_M6_EN_1 {
@ V5 enclosure by M6 >= 5nm
    ENC V5_v_edges M6 < 0.005 ABUT<90 OPPOSITE REGION
}


// =======================================================
// M6: M6 design rules                           
// =======================================================  

GROUP GM6 M6_?

M6_W_1 {
@ Minimum Vertical width >= 30nm
    INT M6_h_edges < 0.030 ABUT<90 REGION
}

M6_S_1 {
@ Minimum Vertical spacing >= 25nm
    EXT M6_h_edges < 0.025 ABUT<90 REGION
}

M6_S_2 {
@ Minimum Horizontal(TtT) spacing between two M6 layers on the same track >= 32nm
    EXT M6_v_edges < 0.032 ABUT<90 OPPOSITE REGION
}

M6_S_3 {
@ Minimum corner-to-corner spacing between two M6 polygons >= 28nm
    EXT M6 < 0.028 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

M6_AUX_1 {
@ M6 must not bend
    NOT RECTANGLE M6 ORTHOGONAL ONLY
}



// =======================================================
// V6: V6 design rules                           
// =======================================================  

GROUP GV6 V6_?

V6_M6 = V6 INTERACT M6
V6_M6_h_edges = ANGLE V6_M6 == 0
V6_M6_v_edges = ANGLE V6_M6 == 90

V6_M7 = V6 INTERACT M7
V6_M7_h_edges = ANGLE V6_M7 == 0
V6_M7_v_edges = ANGLE V6_M7 == 90


V6_W_1 {
@ Minimum width >= 30nm
    INT V6 < 0.030 ABUT<90 SINGULAR REGION
}

V6_S_1 {
@ Minimum corner to corner spacing >= 25nm
    EXT V6 < 0.025 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

V6_M6_AUX_1 {
@ V6 must exactly be the same vertical width with M6
    NOT COIN EDGE V6_M6_h_edges M6
}

V6_M7_AUX_2 {
@ V6 must exactly be the same Horizontal width with M7
    NOT COIN EDGE V6_M7_v_edges M7
}

V6_AUX_3 {
@ V6 must interact with M6 and M7
    (V6 NOT M6) OR (V6 NOT M7)
}


V6_M6_EN_2 {
@ V6 enclosure by M6 >= 5nm
    ENC V6_v_edges M6 < 0.005 ABUT<90 OPPOSITE REGION
