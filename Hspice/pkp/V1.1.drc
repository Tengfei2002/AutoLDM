// =======================================================
// M7: M7 design rules                           
// =======================================================  

GROUP GM7 M7_?

M7_W_1 {
@ Minimum Horizontal width >= 35nm
    INT M7_v_edges < 0.035 ABUT<90 REGION
}

M7_S_1 {
@ Minimum Horizontalspacing >= 25nm
    EXT M7_v_edges < 0.025 ABUT<90 REGION
}

M7_S_2 {
@ Minimum Horizontal(TtT) spacing between two M7 layers on the same track >= 32nm
    EXT M7_v_edges < 0.032 ABUT<90 OPPOSITE REGION
}

M7_S_3 {
@ Minimum corner-to-corner spacing between two M7 polygons >= 28nm
    EXT M7 < 0.028 CORNER TO CORNER ABUT<90 SINGULAR REGION
}

M7_AUX_1 {
@ M7 must not bend
    NOT RECTANGLE M7 ORTHOGONAL ONLY
}



