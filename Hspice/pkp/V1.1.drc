// ############################################
// metal stack configuration control         
// ############################################
// ---------------------------------------------------------------------------------------------
// generate the layer list for all metal and via
// --------------metal-0~metal-9 selection------------------------------------------------------
M0 = COPY M0i     
M1 = COPY M1i     
M2 = COPY M2i     
M3 = COPY M3i     
M4 = COPY M4i     
M5 = COPY M5i     
M6 = COPY M6i     
M7 = COPY M7i     
M8 = COPY M8i     
M9 = COPY M9i     
M10 = COPY M10i     
M11 = COPY M11i     
M12 = COPY M12i     
M13 = COPY M13i     

V0 = COPY V0i
V1 = COPY V1i
V2 = COPY V2i
V3 = COPY V3i
V4 = COPY V4i
V5 = COPY V5i
V6 = COPY V6i
V7 = COPY V7i
V8 = COPY V8i
V9 = COPY V9i
V10 = COPY V10i
V11 = COPY V11i
V12 = COPY V12i


// ============================
// Chip / Extent           
// ============================
DRC:1 = EXTENT DRAWN ORIGINAL
BULK = SIZE DRC:1 BY 1.0   
PW = BULK NOT NW 


// ============================
// Common derivations          
// ============================ 
AA = COPY AAi
GT = COPY GTi  
SN = COPY NIM
SP = COPY PIM
ALL_SN_SP = SN OR SP

GT_0 = GT NOT GCUT


// ============================ 
// Vertical/Horizontal Edges    
// ============================  
AA_h_edges = ANGLE AA == 0 
AA_v_edges = ANGLE AA == 90    

GT_h_edges = ANGLE GT == 0 
GT_v_edges = ANGLE GT == 90   

GT_0_h_edges = ANGLE GT_0 == 0 
GT_0_v_edges = ANGLE GT_0 == 90   

NS_h_edges = ANGLE NSH == 0 
NS_v_edges = ANGLE NSH == 90   

NW_h_edges = ANGLE NW == 0 
NW_v_edges = ANGLE NW == 90   

SP_h_edges = ANGLE SP == 0 
SP_v_edges = ANGLE SP == 90   

SN_h_edges = ANGLE SN == 0 
SN_v_edges = ANGLE SN == 90   

CT_h_edges = ANGLE CT == 0 
CT_v_edges = ANGLE CT == 90   

GCUT_h_edges = ANGLE GCUT == 0 
GCUT_v_edges = ANGLE GCUT == 90   

CT_PR_h_edges = ANGLE CT_PR == 0 
CT_PR_v_edges = ANGLE CT_PR == 90   

VCT_h_edges = ANGLE VCT == 0 
VCT_v_edges = ANGLE VCT == 90   

VCT_PR_h_edges = ANGLE VCT_PR == 0 
VCT_PR_v_edges = ANGLE VCT_PR == 90   

VCG_h_edges = ANGLE VCG == 0 
VCG_v_edges = ANGLE VCG == 90   

M0_h_edges = ANGLE M0 == 0 
M0_v_edges = ANGLE M0 == 90   

M1_h_edges = ANGLE M1 == 0 
M1_v_edges = ANGLE M1 == 90   

M2_h_edges = ANGLE M2 == 0 
M2_v_edges = ANGLE M2 == 90   

M3_h_edges = ANGLE M3 == 0 
M3_v_edges = ANGLE M3 == 90   

M4_h_edges = ANGLE M4 == 0 
M4_v_edges = ANGLE M4 == 90   

M5_h_edges = ANGLE M5 == 0 
M5_v_edges = ANGLE M5 == 90   

M6_h_edges = ANGLE M6 == 0 
M6_v_edges = ANGLE M6 == 90   

M7_h_edges = ANGLE M7 == 0 
M7_v_edges = ANGLE M7 == 90   

M8_h_edges = ANGLE M8 == 0 
M8_v_edges = ANGLE M8 == 90   

M9_h_edges = ANGLE M9 == 0 
M9_v_edges = ANGLE M9 == 90   

M10_h_edges = ANGLE M10 == 0 
M10_v_edges = ANGLE M10 == 90   

M11_h_edges = ANGLE M11 == 0 
M11_v_edges = ANGLE M11 == 90   

M12_h_edges = ANGLE M12 == 0 
M12_v_edges = ANGLE M12 == 90   

M13_h_edges = ANGLE M13 == 0 
M13_v_edges = ANGLE M13 == 90   

M0_PR_h_edges = ANGLE M0_PR == 0 
M0_PR_v_edges = ANGLE M0_PR == 90   

V0_h_edges = ANGLE V0 == 0 
V0_v_edges = ANGLE V0 == 90   

V1_h_edges = ANGLE V1 == 0 
V1_v_edges = ANGLE V1 == 90   

V2_h_edges = ANGLE V2 == 0 
V2_v_edges = ANGLE V2 == 90   

V3_h_edges = ANGLE V3 == 0 
V3_v_edges = ANGLE V3 == 90   

V4_h_edges = ANGLE V4 == 0 
V4_v_edges = ANGLE V4 == 90   

V5_h_edges = ANGLE V5 == 0 
V5_v_edges = ANGLE V5 == 90   

V6_h_edges = ANGLE V6 == 0 
V6_v_edges = ANGLE V6 == 90   

V7_h_edges = ANGLE V7 == 0 
V7_v_edges = ANGLE V7 == 90   

V8_h_edges = ANGLE V8 == 0 
V8_v_edges = ANGLE V8 == 90   

V9_h_edges = ANGLE V9 == 0 
V9_v_edges = ANGLE V9 == 90   

V10_h_edges = ANGLE V10 == 0 
V10_v_edges = ANGLE V10 == 90   

V11_h_edges = ANGLE V11 == 0 
V11_v_edges = ANGLE V11 == 90   

V12_h_edges = ANGLE V12 == 0 
V12_v_edges = ANGLE V12 == 90   

AA_convex_90_270_edges = CONVEX EDGE AA ANGLE1==90 ANGLE2==270
AA_convex_270_270_edges = CONVEX EDGE AA ANGLE1==270 ANGLE2==270


// ============================
// S/D derivation              
// ============================
GATE = GT AND AA  //;gate
NGATE = GATE AND SN  //;n+ gate
PGATE = GATE AND SP  //;p+ gate

PAA = AA AND SP                
NAA = AA AND SN                
PNAA = OR PAA NAA              

//;active AA   
NACT = NAA NOT NW  //;N+AA
PACT = PAA AND NW  //;P+AA
ACT = NACT OR PACT  //;ACTIVE

//;source/drain/active AA for connection
PSD = PACT NOT GT    
NSD = NACT NOT GT    
SD = PSD OR NSD      

real_PSD = PSD INTERACT PGATE 
real_NSD = NSD INTERACT NGATE 
real_SD = OR real_PSD real_NSD   

//;pick-up AA  
NTAP = NAA AND NW
PTAP = PAA NOT NW
TAP = OR NTAP PTAP

AA_c = OR PSD NSD real_PSD real_NSD NTAP PTAP


// --------------------------------------------------------------
// Beginning of the FEOL/BEOL connection for global DRC check
// --------------------------------------------------------------
CONNECT CT M0 BY VCT
CONNECT GT_0 M0 BY VCG

CONNECT CT real_PSD
CONNECT CT real_NSD
CONNECT CT PSD
CONNECT CT NSD
CONNECT CT PTAP
CONNECT CT NTAP
CONNECT CT GT_0

CONNECT AAi PTAP     
CONNECT AAi NTAP     
CONNECT AAi PSD     
CONNECT AAi NSD     
CONNECT real_PSD PSD // pass connectivity from P+ACTIVE to real_PSD
CONNECT real_NSD NSD  

CONNECT NTAP NW                          
CONNECT PTAP PW  

//; For BEOL mapping layers connection 
CONNECT M0 M1 BY V0
CONNECT M1 M2 BY V1
CONNECT M2 M3 BY V2
CONNECT M3 M4 BY V3
CONNECT M4 M5 BY V4
CONNECT M5 M6 BY V5
CONNECT M6 M7 BY V6     
CONNECT M7 M8 BY V7     
CONNECT M8 M9 BY V8     
CONNECT M9 M10 BY V9     
CONNECT M10 M11 BY V10     
CONNECT M11 M12 BY V11     
CONNECT M12 M13 BY V12     
// --------------------------------------------------------------
// End of the FEOL/BEOL connection for global DRC check          
// --------------------------------------------------------------   

VIRTUAL CONNECT NAME ?VDD? ?VCC? ?VSS? ?GND?          
VIRTUAL CONNECT COLON YES  


// =======================     
// GATE derivation             
// =======================     
GATE_WE = GATE COIN EDGE GT     //; channel width
GATE_LE = (GATE INTERACT (AA NOT GATE) >= 2) COIN EDGE AA //; channel length 


// =======================================================
// Design requirements                                    
// =======================================================

GROUP GGR GR_?  

GR_1_2_M0 {
@ All the geometry design must be an integer multiple of 0.001um. 
@ Design shape geometry all vertices and intersections of 45-degree polygon must be on an integer multiple of 0.001um.
    OFFGRID M0 10
}

