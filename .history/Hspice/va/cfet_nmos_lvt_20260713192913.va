   real tgaamin = 5.0e-9;
   real wgaamax = 4.0e-8;
   real wgaamin = 1.0e-8;
   real lgaamax = 1e-7;
   real lgaamin = 1.6e-8;
	 real netmax  = 1.0; 
	 real netmin  = -1.0; 




