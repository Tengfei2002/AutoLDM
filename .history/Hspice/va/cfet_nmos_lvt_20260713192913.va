//  Notes:
//    - GAA global model (Lg: 16-100 nm; WGAA: 10-40 nm).
//    - Current and capacitance merged.
//    - Derived from BSIM-CMG ver.111.2.1 with the fusion modeling
//      technique [B. Peng et al., "PHIMO-NN: Compact Modeling by
//      Fusing Device Physics and Neural Networks for One-Shot
//      Parameterization," IEEE TCAD].
//    - The Verilog-A code corresponds to the model's Python
//      implementation used for training and adopts a re-organized
//      structure for clarity.
//
/**********************************************************************/



`include "constants.vams"
`include "disciplines.vams"
(* instance_parameter_list = {L, W, NF, U0, XL, DVTSHIFT, DeltaWGAA, DeltaTGAA, EOT_0} *)
module cfet_nmos_lvt(D, G, S, B);
   inout D, G, S, B;
   electrical D, G, S, B;

//***** primary device structure / instance parameters ******//
parameter real L=1.6e-08;
parameter real W=2.5e-08;
parameter real NF=1;
parameter real U0 = 2.465126225809e-02;
parameter real XL=4.677576751588e-09;
parameter real DVTSHIFT=2.340310883015e-01;		//###########1111
parameter real DeltaWGAA = 2.048235619238e-09;
parameter real DeltaTGAA = 1.409403394487e-09;
parameter real EOT_0 = 7.9e-10;				//###########1111

