/////////////////////////////////////////////////////////////////////////////////////////////////////////////
   //****** Activation function tansig ******//
   analog function real Tanh;
						input var_g;
						real var_g;
						
						begin
								 Tanh = (1.0 - exp(-2.0*var_g))/(1.0 + exp(-2.0*var_g));
						end
		 endfunction
   
   //****** Activation function logsig ******//
   analog function real Sigmoid;
						input var_l;
						real  var_l;
						
						begin
								 Sigmoid = 1.0 / (1.0 + exp(-1.0 * var_l));
						end
   endfunction

`define EXPL_THRESHOLD 80.0
`define MAX_EXPL 5.540622384e34
`define MIN_EXPL 1.804851387e-35
`define N_MINLOG 1.0e-38
`define LN_N_MINLOG -87.498233534

// Clamped exponential
`define lexp(x) ((x > `EXPL_THRESHOLD) ? `MAX_EXPL * (1.0 + x - `EXPL_THRESHOLD) : (x < -`EXPL_THRESHOLD) ? `MIN_EXPL : exp(x))

// Clamped logarithm
`define lln(x) ((x > `N_MINLOG) ? ln(x) : `LN_N_MINLOG)

// Hyperbolic smoothing
`define hypsmooth(x, c) (0.5 * (x + sqrt(x * x + 4.0 * c * c)))

// Smoothing with a minimum value
`define smoothminx(x, x0, deltax) (0.5 * (x + x0 + sqrt((x - x0) * (x - x0) + 0.25 * deltax * deltax)))

// Smoothing with a maximum value
`define smoothmaxx(x, x0, deltax) (0.5 * (x + x0 - sqrt((x - x0) * (x - x0) + 0.25 * deltax * deltax)) + 0.25 * deltax)

// Smoothing with a maximum value
`define smoothmaxx2(x, x0, deltax) (0.5 * (x + x0 - sqrt((x - x0) * (x - x0) + 0.25 * deltax * deltax)))

//Gamma function
`define gammafunc(x) (0.0385 * exp(-4.6 * (x-1)) + 7.5893e-7 * pow(2*x - 3, 8) + 6.9583e-5 * pow(2*(x-1), 6) - 6.583e-4 * pow(2*(x-1), 5) + 0.0065 * pow(2*(x-1), 4) - 0.026 * pow(2*(x-1), 3) + 0.1371 * pow(2*(x-1), 2) - 0.194 * 2*(x-1) + 0.959)

// Binning equations
`define binning(param_i, r_term, l_term, n_term, p_term, w_term, wl_term) \
begin \
    param_i = r_term + Inv_L * l_term + Inv_NFIN * n_term + Inv_LNFIN * p_term + Inv_W * w_term + Inv_WL * wl_term; \
end





   //****the calculation starts****//
   analog
		  begin
			Lg = L + XL;
	   //****** input normalizations ******//
	 		//tgaa_nor = ((TGAA - tgaamin) / (tgaamax - tgaamin)) * (netmax-netmin) + netmin;
	 		//w_nor    = ((WGAA - wgaamin) / (wgaamax - wgaamin)) * (netmax-netmin) + netmin;
			tgaa_nor = 1.0;
	 		w_nor    = ((WGAA - wgaamin) / (wgaamax - wgaamin)) * (netmax-netmin) + netmin;//###########1111
			tgaa_nor =1;	 			//###########1111
	 		l_nor    = ((L - lgaamin) / (lgaamax - lgaamin)) * (netmax-netmin) + netmin;//###########1111
	   //****** calculation starts NN1 SCE Model******//
	   //***1st layer***//
      neuronsce1_1_in  = nnscew1_1_1*w_nor +nnscew1_1_2*l_nor +nnsceb1_1;
   	  neuronsce1_2_in  = nnscew1_2_1*w_nor +nnscew1_2_2*l_nor +nnsceb1_2;
	   	neuronsce1_1_out =Sigmoid(neuronsce1_1_in);
      neuronsce1_2_out =Sigmoid(neuronsce1_2_in);
	   //***2nd layer***//
      neuronsce2_1_in  = nnscew2_1_1*neuronsce1_1_out + nnscew2_1_2*neuronsce1_2_out + nnsceb2_1;
   	  neuronsce2_2_in  = nnscew2_2_1*neuronsce1_1_out + nnscew2_2_2*neuronsce1_2_out + nnsceb2_2;
	   	neuronsce2_1_out =Sigmoid(neuronsce2_1_in);
      neuronsce2_2_out =Sigmoid(neuronsce2_2_in);
	   //***Output layer***//
      neuronsce3_1_in  = nnscew3_1_1*neuronsce2_1_out + nnscew3_1_2*neuronsce2_2_out + nnsceb3_1;
   	  neuronsce3_2_in  = nnscew3_2_1*neuronsce2_1_out + nnscew3_2_2*neuronsce2_2_out + nnsceb3_2;
      neuronsce3_3_in  = nnscew3_3_1*neuronsce2_1_out + nnscew3_3_2*neuronsce2_2_out + nnsceb3_3;
   	  neuronsce3_4_in  = nnscew3_4_1*neuronsce2_1_out + nnscew3_4_2*neuronsce2_2_out + nnsceb3_4;
      neuronsce3_5_in  = nnscew3_5_1*neuronsce2_1_out + nnscew3_5_2*neuronsce2_2_out + nnsceb3_5;
	   	neuronsce3_1_out =Sigmoid(neuronsce3_1_in);
      neuronsce3_2_out =Sigmoid(neuronsce3_2_in);
	   	neuronsce3_3_out =Sigmoid(neuronsce3_3_in);
      neuronsce3_4_out =Sigmoid(neuronsce3_4_in);			
	   	neuronsce3_5_out =Sigmoid(neuronsce3_5_in);
			
			sce_output1 = 5 * neuronsce3_1_out;	
			sce_output2 = 5 * neuronsce3_2_out;	
			sce_output3 = 5 * neuronsce3_3_out;	
			sce_output4 = 5 * neuronsce3_4_out;	
			sce_output5 = 5 * neuronsce3_5_out;	
	   //****** calculation ends NN1 SCE Model******//

	   //****** calculation starts NN2 CLM Verlocity Saturation Model******//
	   //***1st layer***//
      neuronclm1_1_in  = nnclmw1_1_1*w_nor +nnclmw1_1_2*l_nor +nnclmb1_1;
   	  neuronclm1_2_in  = nnclmw1_2_1*w_nor +nnclmw1_2_2*l_nor +nnclmb1_2;
      neuronclm1_3_in  = nnclmw1_3_1*w_nor +nnclmw1_3_2*l_nor +nnclmb1_3;
   	  neuronclm1_4_in  = nnclmw1_4_1*w_nor +nnclmw1_4_2*l_nor +nnclmb1_4;
	   	neuronclm1_1_out =Sigmoid(neuronclm1_1_in);
      neuronclm1_2_out =Sigmoid(neuronclm1_2_in);
	   	neuronclm1_3_out =Sigmoid(neuronclm1_3_in);
      neuronclm1_4_out =Sigmoid(neuronclm1_4_in);
	   //***2nd layer***//
      neuronclm2_1_in  = nnclmw2_1_1*neuronclm1_1_out + nnclmw2_1_2*neuronclm1_2_out + nnclmw2_1_3*neuronclm1_3_out + nnclmw2_1_4*neuronclm1_4_out + nnclmb2_1;
   	  neuronclm2_2_in  = nnclmw2_2_1*neuronclm1_1_out + nnclmw2_2_2*neuronclm1_2_out + nnclmw2_2_3*neuronclm1_3_out + nnclmw2_2_4*neuronclm1_4_out + nnclmb2_2;
      neuronclm2_3_in  = nnclmw2_3_1*neuronclm1_1_out + nnclmw2_3_2*neuronclm1_2_out + nnclmw2_3_3*neuronclm1_3_out + nnclmw2_3_4*neuronclm1_4_out + nnclmb2_3;
   	  neuronclm2_4_in  = nnclmw2_4_1*neuronclm1_1_out + nnclmw2_4_2*neuronclm1_2_out + nnclmw2_4_3*neuronclm1_3_out + nnclmw2_4_4*neuronclm1_4_out + nnclmb2_4;
	   	neuronclm2_1_out =Sigmoid(neuronclm2_1_in);
      neuronclm2_2_out =Sigmoid(neuronclm2_2_in);
	   	neuronclm2_3_out =Sigmoid(neuronclm2_3_in);
      neuronclm2_4_out =Sigmoid(neuronclm2_4_in);
	   //***Output layer***//
      neuronclm3_1_in  = nnclmw3_1_1*neuronclm2_1_out + nnclmw3_1_2*neuronclm2_2_out + nnclmw3_1_3*neuronclm2_3_out + nnclmw3_1_4*neuronclm2_4_out + nnclmb3_1;
      neuronclm3_2_in  = nnclmw3_2_1*neuronclm2_1_out + nnclmw3_2_2*neuronclm2_2_out + nnclmw3_2_3*neuronclm2_3_out + nnclmw3_2_4*neuronclm2_4_out + nnclmb3_2;
      neuronclm3_3_in  = nnclmw3_3_1*neuronclm2_1_out + nnclmw3_3_2*neuronclm2_2_out + nnclmw3_3_3*neuronclm2_3_out + nnclmw3_3_4*neuronclm2_4_out + nnclmb3_3;
      neuronclm3_4_in  = nnclmw3_4_1*neuronclm2_1_out + nnclmw3_4_2*neuronclm2_2_out + nnclmw3_4_3*neuronclm2_3_out + nnclmw3_4_4*neuronclm2_4_out + nnclmb3_4;
      neuronclm3_5_in  = nnclmw3_5_1*neuronclm2_1_out + nnclmw3_5_2*neuronclm2_2_out + nnclmw3_5_3*neuronclm2_3_out + nnclmw3_5_4*neuronclm2_4_out + nnclmb3_5;
      neuronclm3_6_in  = nnclmw3_6_1*neuronclm2_1_out + nnclmw3_6_2*neuronclm2_2_out + nnclmw3_6_3*neuronclm2_3_out + nnclmw3_6_4*neuronclm2_4_out + nnclmb3_6;
      neuronclm3_7_in  = nnclmw3_7_1*neuronclm2_1_out + nnclmw3_7_2*neuronclm2_2_out + nnclmw3_7_3*neuronclm2_3_out + nnclmw3_7_4*neuronclm2_4_out + nnclmb3_7;
      neuronclm3_8_in  = nnclmw3_8_1*neuronclm2_1_out + nnclmw3_8_2*neuronclm2_2_out + nnclmw3_8_3*neuronclm2_3_out + nnclmw3_8_4*neuronclm2_4_out + nnclmb3_8;
      neuronclm3_9_in  = nnclmw3_9_1*neuronclm2_1_out + nnclmw3_9_2*neuronclm2_2_out + nnclmw3_9_3*neuronclm2_3_out + nnclmw3_9_4*neuronclm2_4_out + nnclmb3_9;
      neuronclm3_10_in  = nnclmw3_10_1*neuronclm2_1_out + nnclmw3_10_2*neuronclm2_2_out + nnclmw3_10_3*neuronclm2_3_out + nnclmw3_10_4*neuronclm2_4_out + nnclmb3_10;
      neuronclm3_11_in  = nnclmw3_11_1*neuronclm2_1_out + nnclmw3_11_2*neuronclm2_2_out + nnclmw3_11_3*neuronclm2_3_out + nnclmw3_11_4*neuronclm2_4_out + nnclmb3_11;
      neuronclm3_12_in  = nnclmw3_12_1*neuronclm2_1_out + nnclmw3_12_2*neuronclm2_2_out + nnclmw3_12_3*neuronclm2_3_out + nnclmw3_12_4*neuronclm2_4_out + nnclmb3_12;
      neuronclm3_13_in  = nnclmw3_13_1*neuronclm2_1_out + nnclmw3_13_2*neuronclm2_2_out + nnclmw3_13_3*neuronclm2_3_out + nnclmw3_13_4*neuronclm2_4_out + nnclmb3_13;
	   	neuronclm3_1_out =Sigmoid(neuronclm3_1_in);
      neuronclm3_2_out =Sigmoid(neuronclm3_2_in);
	   	neuronclm3_3_out =Sigmoid(neuronclm3_3_in);
      neuronclm3_4_out =Sigmoid(neuronclm3_4_in);			
	   	neuronclm3_5_out =Sigmoid(neuronclm3_5_in);
	   	neuronclm3_6_out =Sigmoid(neuronclm3_6_in);
      neuronclm3_7_out =Sigmoid(neuronclm3_7_in);
	   	neuronclm3_8_out =Sigmoid(neuronclm3_8_in);
      neuronclm3_9_out =Sigmoid(neuronclm3_9_in);			
	   	neuronclm3_10_out =Sigmoid(neuronclm3_10_in);
	   	neuronclm3_11_out =Sigmoid(neuronclm3_11_in);
      neuronclm3_12_out =Sigmoid(neuronclm3_12_in);
	   	neuronclm3_13_out =Sigmoid(neuronclm3_13_in);
			
			clm_output1 = 5 * neuronclm3_1_out;	
			clm_output2 = 5 * neuronclm3_2_out;	
			clm_output3 = 5 * neuronclm3_3_out;	
			clm_output4 = 5 * neuronclm3_4_out;	
			clm_output5 = 5 * neuronclm3_5_out;	
			clm_output6 = 5 * neuronclm3_6_out;	
			clm_output7 = 5 * neuronclm3_7_out;	
			clm_output8 = 5 * neuronclm3_8_out;	
			clm_output9 = 5 * neuronclm3_9_out;	
			clm_output10 = 5 * neuronclm3_10_out;	
			clm_output11 = 5 * neuronclm3_11_out;	
			clm_output12 = 5 * neuronclm3_12_out;	
			clm_output13 = 5 * neuronclm3_13_out;	
	   //****** calculation ends NN2 CLM Verlocity Saturation Model******//

	   //****** calculation starts NN3 Quantum Model******//
	   //***1st layer***//
			neuronqua1_1_in = nnquaw1_1_1*l_nor + nnquaw1_1_2*w_nor + nnquab1_1;
			neuronqua1_2_in = nnquaw1_2_1*l_nor + nnquaw1_2_2*w_nor + nnquab1_2;
			neuronqua1_3_in = nnquaw1_3_1*l_nor + nnquaw1_3_2*w_nor + nnquab1_3;
			neuronqua1_1_out = Sigmoid(neuronqua1_1_in);
			neuronqua1_2_out = Sigmoid(neuronqua1_2_in);
			neuronqua1_3_out = Sigmoid(neuronqua1_3_in);
	   //***2nd layer***//
			neuronqua2_1_in = nnquaw2_1_1*neuronqua1_1_out + nnquaw2_1_2*neuronqua1_2_out + nnquaw2_1_3*neuronqua1_3_out + nnquab2_1;
			neuronqua2_2_in = nnquaw2_2_1*neuronqua1_1_out + nnquaw2_2_2*neuronqua1_2_out + nnquaw2_2_3*neuronqua1_3_out + nnquab2_2;
			neuronqua2_3_in = nnquaw2_3_1*neuronqua1_1_out + nnquaw2_3_2*neuronqua1_2_out + nnquaw2_3_3*neuronqua1_3_out + nnquab2_3;
			neuronqua2_1_out = Sigmoid(neuronqua2_1_in);
			neuronqua2_2_out = Sigmoid(neuronqua2_2_in);
			neuronqua2_3_out = Sigmoid(neuronqua2_3_in);
	   //***Output layer***//
			neuronqua3_1_in = nnquaw3_1_1*neuronqua2_1_out + nnquaw3_1_2*neuronqua2_2_out + nnquaw3_1_3*neuronqua2_3_out + nnquaw3_1_4*neuronqua2_4_out + nnquab3_1;
			neuronqua3_2_in = nnquaw3_2_1*neuronqua2_1_out + nnquaw3_2_2*neuronqua2_2_out + nnquaw3_2_3*neuronqua2_3_out + nnquaw3_2_4*neuronqua2_4_out + nnquab3_2;
			neuronqua3_3_in = nnquaw3_3_1*neuronqua2_1_out + nnquaw3_3_2*neuronqua2_2_out + nnquaw3_3_3*neuronqua2_3_out + nnquaw3_3_4*neuronqua2_4_out + nnquab3_3;
			neuronqua3_4_in = nnquaw3_4_1*neuronqua2_1_out + nnquaw3_4_2*neuronqua2_2_out + nnquaw3_4_3*neuronqua2_3_out + nnquaw3_4_4*neuronqua2_4_out + nnquab3_4;
			neuronqua3_5_in = nnquaw3_5_1*neuronqua2_1_out + nnquaw3_5_2*neuronqua2_2_out + nnquaw3_5_3*neuronqua2_3_out + nnquaw3_5_4*neuronqua2_4_out + nnquab3_5;
			neuronqua3_6_in = nnquaw3_6_1*neuronqua2_1_out + nnquaw3_6_2*neuronqua2_2_out + nnquaw3_6_3*neuronqua2_3_out + nnquaw3_6_4*neuronqua2_4_out + nnquab3_6;
			neuronqua3_7_in = nnquaw3_7_1*neuronqua2_1_out + nnquaw3_7_2*neuronqua2_2_out + nnquaw3_7_3*neuronqua2_3_out + nnquaw3_7_4*neuronqua2_4_out + nnquab3_7;
			neuronqua3_1_out = Sigmoid(neuronqua3_1_in);
			neuronqua3_2_out = Sigmoid(neuronqua3_2_in);
			neuronqua3_3_out = Sigmoid(neuronqua3_3_in);
			neuronqua3_4_out = Sigmoid(neuronqua3_4_in);
			neuronqua3_5_out = Sigmoid(neuronqua3_5_in);
			neuronqua3_6_out = Sigmoid(neuronqua3_6_in);
			neuronqua3_7_out = Sigmoid(neuronqua3_7_in);


			qua_output1 = 5 * neuronqua3_1_out;	
			qua_output2 = 5 * neuronqua3_2_out;	
			qua_output3 = 5 * neuronqua3_3_out;	
			gidl_output4 = 5 * neuronqua3_4_out;	
			gidl_output5 = 5 * neuronqua3_5_out;	
			gidl_output6 = 5 * neuronqua3_6_out;	
			gidl_output7 = 5 * neuronqua3_7_out;	
	   //****** calculation ends NN3 Quantum Model******//

	   //****** calculation starts NN4 Mobility Model******//
	   //***1st layer***//
			neuronmob1_1_in = nnmobw1_1_1*tgaa_nor + nnmobw1_1_2*w_nor + nnmobw1_1_3*l_nor + nnmobb1_1;
			neuronmob1_2_in = nnmobw1_2_1*tgaa_nor + nnmobw1_2_2*w_nor + nnmobw1_2_3*l_nor + nnmobb1_2;
			neuronmob1_1_out = Sigmoid(neuronmob1_1_in);
			neuronmob1_2_out = Sigmoid(neuronmob1_2_in);
	   //***2nd layer***//
			neuronmob2_1_in = nnmobw2_1_1*neuronmob1_1_out + nnmobw2_1_2*neuronmob1_2_out + nnmobb2_1;
			neuronmob2_2_in = nnmobw2_2_1*neuronmob1_1_out + nnmobw2_2_2*neuronmob1_2_out + nnmobb2_2;
			neuronmob2_1_out = Sigmoid(neuronmob2_1_in);
			neuronmob2_2_out = Sigmoid(neuronmob2_2_in);
	   //***Output layer***//
			neuronmob3_1_in = nnmobw3_1_1*neuronmob2_1_out + nnmobw3_1_2*neuronmob2_2_out + nnmobb3_1;
			neuronmob3_2_in = nnmobw3_2_1*neuronmob2_1_out + nnmobw3_2_2*neuronmob2_2_out + nnmobb3_2;
			neuronmob3_3_in = nnmobw3_3_1*neuronmob2_1_out + nnmobw3_3_2*neuronmob2_2_out + nnmobb3_3;
			neuronmob3_4_in = nnmobw3_4_1*neuronmob2_1_out + nnmobw3_4_2*neuronmob2_2_out + nnmobb3_4;
			neuronmob3_5_in = nnmobw3_5_1*neuronmob2_1_out + nnmobw3_5_2*neuronmob2_2_out + nnmobb3_5;
			neuronmob3_1_out = Sigmoid(neuronmob3_1_in);
			neuronmob3_2_out = Sigmoid(neuronmob3_2_in);
			neuronmob3_3_out = Sigmoid(neuronmob3_3_in);
			neuronmob3_4_out = Sigmoid(neuronmob3_4_in);
			neuronmob3_5_out = Sigmoid(neuronmob3_5_in);

			mob_output1 = 5 * neuronmob3_1_out;	
			mob_output2 = 5 * neuronmob3_2_out;	
			mob_output3 = 5 * neuronmob3_3_out;	
			mob_output4 = 5 * neuronmob3_4_out;	
			mob_output5 = 5 * neuronmob3_5_out;	
	   //****** calculation ends NN4 Mobility Model******//

	   //****** calculation starts NN5 CV Model******//
	   //***1st layer***//
			neuroncv1_1_in = nncvw1_1_1*tgaa_nor + nncvw1_1_2*w_nor + nncvw1_1_3*l_nor + nncvb1_1;
			neuroncv1_2_in = nncvw1_2_1*tgaa_nor + nncvw1_2_2*w_nor + nncvw1_2_3*l_nor + nncvb1_2;
			neuroncv1_3_in = nncvw1_3_1*tgaa_nor + nncvw1_3_2*w_nor + nncvw1_3_3*l_nor + nncvb1_3;
			neuroncv1_4_in = nncvw1_4_1*tgaa_nor + nncvw1_4_2*w_nor + nncvw1_4_3*l_nor + nncvb1_4;
			neuroncv1_1_out = Sigmoid(neuroncv1_1_in);
			neuroncv1_2_out = Sigmoid(neuroncv1_2_in);
			neuroncv1_3_out = Sigmoid(neuroncv1_3_in);
			neuroncv1_4_out = Sigmoid(neuroncv1_4_in);
	   //***2nd layer***//
			neuroncv2_1_in = nncvw2_1_1*neuroncv1_1_out + nncvw2_1_2*neuroncv1_2_out + nncvw2_1_3*neuroncv1_3_out + nncvw2_1_4*neuroncv1_4_out + nncvb2_1;
			neuroncv2_2_in = nncvw2_2_1*neuroncv1_1_out + nncvw2_2_2*neuroncv1_2_out + nncvw2_2_3*neuroncv1_3_out + nncvw2_2_4*neuroncv1_4_out + nncvb2_2;
			neuroncv2_3_in = nncvw2_3_1*neuroncv1_1_out + nncvw2_3_2*neuroncv1_2_out + nncvw2_3_3*neuroncv1_3_out + nncvw2_3_4*neuroncv1_4_out + nncvb2_3;
			neuroncv2_4_in = nncvw2_4_1*neuroncv1_1_out + nncvw2_4_2*neuroncv1_2_out + nncvw2_4_3*neuroncv1_3_out + nncvw2_4_4*neuroncv1_4_out + nncvb2_4;
			neuroncv2_1_out = Sigmoid(neuroncv2_1_in);
			neuroncv2_2_out = Sigmoid(neuroncv2_2_in);
			neuroncv2_3_out = Sigmoid(neuroncv2_3_in);
			neuroncv2_4_out = Sigmoid(neuroncv2_4_in);
	   //***Output layer***//
			neuroncv3_1_in = nncvw3_1_1*neuroncv2_1_out + nncvw3_1_2*neuroncv2_2_out + nncvw3_1_3*neuroncv2_3_out + nncvw3_1_4*neuroncv2_4_out + nncvb3_1;
			neuroncv3_2_in = nncvw3_2_1*neuroncv2_1_out + nncvw3_2_2*neuroncv2_2_out + nncvw3_2_3*neuroncv2_3_out + nncvw3_2_4*neuroncv2_4_out + nncvb3_2;
			neuroncv3_3_in = nncvw3_3_1*neuroncv2_1_out + nncvw3_3_2*neuroncv2_2_out + nncvw3_3_3*neuroncv2_3_out + nncvw3_3_4*neuroncv2_4_out + nncvb3_3;
			neuroncv3_4_in = nncvw3_4_1*neuroncv2_1_out + nncvw3_4_2*neuroncv2_2_out + nncvw3_4_3*neuroncv2_3_out + nncvw3_4_4*neuroncv2_4_out + nncvb3_4;
			neuroncv3_5_in = nncvw3_5_1*neuroncv2_1_out + nncvw3_5_2*neuroncv2_2_out + nncvw3_5_3*neuroncv2_3_out + nncvw3_5_4*neuroncv2_4_out + nncvb3_5;
			neuroncv3_6_in = nncvw3_6_1*neuroncv2_1_out + nncvw3_6_2*neuroncv2_2_out + nncvw3_6_3*neuroncv2_3_out + nncvw3_6_4*neuroncv2_4_out + nncvb3_6;
			neuroncv3_7_in = nncvw3_7_1*neuroncv2_1_out + nncvw3_7_2*neuroncv2_2_out + nncvw3_7_3*neuroncv2_3_out + nncvw3_7_4*neuroncv2_4_out + nncvb3_7;
			neuroncv3_8_in = nncvw3_8_1*neuroncv2_1_out + nncvw3_8_2*neuroncv2_2_out + nncvw3_8_3*neuroncv2_3_out + nncvw3_8_4*neuroncv2_4_out + nncvb3_8;
			neuroncv3_9_in = nncvw3_9_1*neuroncv2_1_out + nncvw3_9_2*neuroncv2_2_out + nncvw3_9_3*neuroncv2_3_out + nncvw3_9_4*neuroncv2_4_out + nncvb3_9;
			neuroncv3_10_in = nncvw3_10_1*neuroncv2_1_out + nncvw3_10_2*neuroncv2_2_out + nncvw3_10_3*neuroncv2_3_out + nncvw3_10_4*neuroncv2_4_out + nncvb3_10;
			neuroncv3_11_in = nncvw3_11_1*neuroncv2_1_out + nncvw3_11_2*neuroncv2_2_out + nncvw3_11_3*neuroncv2_3_out + nncvw3_11_4*neuroncv2_4_out + nncvb3_11;
			neuroncv3_12_in = nncvw3_12_1*neuroncv2_1_out + nncvw3_12_2*neuroncv2_2_out + nncvw3_12_3*neuroncv2_3_out + nncvw3_12_4*neuroncv2_4_out + nncvb3_12;
			neuroncv3_13_in = nncvw3_13_1*neuroncv2_1_out + nncvw3_13_2*neuroncv2_2_out + nncvw3_13_3*neuroncv2_3_out + nncvw3_13_4*neuroncv2_4_out + nncvb3_13;
			neuroncv3_14_in = nncvw3_14_1*neuroncv2_1_out + nncvw3_14_2*neuroncv2_2_out + nncvw3_14_3*neuroncv2_3_out + nncvw3_14_4*neuroncv2_4_out + nncvb3_14;
			neuroncv3_15_in = nncvw3_15_1*neuroncv2_1_out + nncvw3_15_2*neuroncv2_2_out + nncvw3_15_3*neuroncv2_3_out + nncvw3_15_4*neuroncv2_4_out + nncvb3_15;
			neuroncv3_1_out = Sigmoid(neuroncv3_1_in);
			neuroncv3_2_out = Sigmoid(neuroncv3_2_in);
			neuroncv3_3_out = Sigmoid(neuroncv3_3_in);
			neuroncv3_4_out = Sigmoid(neuroncv3_4_in);
			neuroncv3_5_out = Sigmoid(neuroncv3_5_in);
			neuroncv3_6_out = Sigmoid(neuroncv3_6_in);
			neuroncv3_7_out = Sigmoid(neuroncv3_7_in);
			neuroncv3_8_out = Sigmoid(neuroncv3_8_in);
			neuroncv3_9_out = Sigmoid(neuroncv3_9_in);
			neuroncv3_10_out = Sigmoid(neuroncv3_10_in);
			neuroncv3_11_out = Sigmoid(neuroncv3_11_in);
			neuroncv3_12_out = Sigmoid(neuroncv3_12_in);
			neuroncv3_13_out = Sigmoid(neuroncv3_13_in);
			neuroncv3_14_out = Sigmoid(neuroncv3_14_in);
			neuroncv3_15_out = Sigmoid(neuroncv3_15_in);

			cv_output1 = 5 * neuroncv3_1_out;	
			cv_output2 = 5 * neuroncv3_2_out;	
			cv_output3 = 5 * neuroncv3_3_out;	
			cv_output4 = 5 * neuroncv3_4_out;	
			cv_output5 = 5 * neuroncv3_5_out;	
			cv_output6 = 5 * neuroncv3_6_out;	
			cv_output7 = 5 * neuroncv3_7_out;	
			cv_output8 = 5 * neuroncv3_8_out;	
			cv_output9 = 5 * neuroncv3_9_out;	
			cv_output10 = 5 * neuroncv3_10_out;	
			cv_output11 = 5 * neuroncv3_11_out;	
			cv_output12 = 5 * neuroncv3_12_out;	
			cv_output13 = 5 * neuroncv3_13_out;	
			cv_output14 = 5 * neuroncv3_14_out;	
			cv_output15 = 5 * neuroncv3_15_out;	
			


	   //****** calculation ends NN5 CV Model******//
			


	   //****** calculation starts Physics Model******//
		 vgs = type * V(G, S);
	   vds = type * V(D, S);

	   //****** Mode choice ******//
	   if (vds >= 0.0)
	     begin 
				 mode = 1.0;
				 vds = vds;
				 vgs = vgs;
			 end
	   else
			 begin
				 mode = -1.0;
				 vds = -vds;
				 vgs = vgs + vds;
	   	 end
		//************************************ Binning ****************************************************//
		//WGAA = WGAA + DeltaWGAA;
		//TGAA = TGAA + DeltaTGAA;
		Inv_L      = 1.0e-6 / Lg;
		Inv_NFIN   = 1.0 / NFIN;
		Inv_LNFIN  = 1.0e-6 / (Lg * NFIN);
		Inv_W      = 1.0e-6 / WGAA;
		Inv_WL     = 1.0e-12 / (WGAA * Lg);

		//************************************  Nanosheet gate Start ****************************************************//
    WGAAeff = WGAA; // Assuming WGAA is already defined

         Weff_UFCM = 2 * (WGAA + DeltaWGAA + TGAA + DeltaTGAA) * NGAA;        //###########1111
         Ach = (WGAA + DeltaWGAA) * (TGAA + DeltaWGAA) * NGAA;                    //###########1111
         EOT = EOT_0*cv_output14;
    Cins = Weff_UFCM * EPSROX * EPS0 / EOT;
		//************************************  Nanosheet gate End ****************************************************//

		//************************************  Geometric scaling for Toxeff / charge centroid Tcen ****************************************************//
    MTcen = 1.0 + AQMTCEN * `lexp(-(2.0 * Ach / Weff_UFCM) / BQMTCEN);
    Tcen0 = (2.0 * Ach / Weff_UFCM) * MTcen;

    // Dimension scaling
    T0 = TOXG * TOXG;
    Weff0 = Weff_UFCM;
    WeffCV0 = Weff_UFCM;


		//************************************   Mobility degradation for GAA Starts ****************************************************//

		ETAMOB_i = mob_output5;


		// NN4-1 UA_i
		UA_i = mob_output1;

		// NN4-2 EU_i
		EU_i = mob_output2;



		U0_i = U0 * mob_output3;

		UD_i = mob_output4; 
		
		Vtm = KboQ * DevTemp;
		nVtm = Vtm;
		Nc = NC0SUB;
		epssub = EPSRSUB * EPS0;
		rc = 2.0 * Cins / (Weff_UFCM * Weff_UFCM * epssub / Ach);
		cox = Cins / Weff_UFCM;
		qbs = q * NBODY * Ach / Cins;
		Qdep_ov_Cins = -q * NBODY * Ach / Cins;
		qdep = Qdep_ov_Cins / nVtm;

		vth_fixed_factor_SI = `lln(Cins * nVtm / (q * Nc * 2.0 * Ach));
		vth_fixed_factor_Sub = `lln((qdep * rc) * (qdep * rc) / ((`lexp(qdep * rc) - qdep * rc - 1.0))) + vth_fixed_factor_SI;
		q0 = 10.0 * nVtm / rc + 2.0 * qbs;
		//************************************   Mobility degradation for GAA Ends ****************************************************//

		//************************************   Short Channel Effect Starts ****************************************************//
		scl = sqrt((epssub * Ach / Cins) * (1.0 + Ach * Cins / (2.0 * epssub * Weff_UFCM * Weff_UFCM)));

		Eg = BG0SUB;
		ni = NI0SUB * `lexp(BG0SUB / (2.0 * KboQ * 300.15) - Eg / (2.0 * Vtm));
		phib = Vtm * `lln(NBODY / ni);

		vbi = Vtm * `lln(NBODY * NSD / (ni * ni));
		// NN1-1 
		tmp = sce_output1 * Lg / scl + 1.0e-6;
		Theta_SCE = 0.5 / (cosh(tmp) - 1.0);
		// NN1-1 
		tmp = sce_output1 * Lg / scl + 1.0e-6;
		Theta_SW = 0.5 / (cosh(tmp) - 1.0);
		// NN1-1 
		tmp = sce_output1 * Lg / scl + 1.0e-6;
		Theta_DIBL = 0.5 / (cosh(tmp) - 1.0);

		Theta_RSCE = sqrt(1.0 + LPE0_i / Lg) - 1.0;

		ThetaSS = `hypsmooth((1.0 - 1.0e-6), 1.0e-3);

		phist = 0.4 + phib + PHIN_i;
		T1 = 2.0 * (Cins / Weff_UFCM) / (rc + 2.0);
		vdsx = sqrt(vds * vds + 0.01) - 0.1;
		// NN1-4:CDSC_i  NN1-5:CDSCD_i 
		cdsc = Theta_SW * (sce_output4 + sce_output5 * vdsx);  
		nVtm = Vtm * ThetaSS * (1.0 + (CIT_i + cdsc) / T1);

		//Quantum mechanical Vth correction
		kT = Vtm * q;
		T0 = HBAR * pi / (2.0 * Ach / Weff_UFCM);
		E0 = T0 * T0 / (2.0 * mx);
		E0prime = T0 * T0 / (2.0 * mxprime);
		E1 = 4.0 * E0;
		E1prime = 4.0 * E0prime;
		T1 = gprime * mdprime / (gfactor * md);
		gam0 = 1.0 + T1 * exp((E0 - E0prime) / kT);
		gam1 = gam0 + `lexp((E0 - E1) / kT) + T1 * `lexp((E0 - E1prime) / kT);
		T2 = -Vtm * `lln(gfactor * md / (pi * HBAR * HBAR * Nc) * kT / (2.0 * Ach / Weff_UFCM) * gam1);
		// NN3-1:QMFACTOR_i  
		dvch_qm = qua_output1 * (E0 / q + T2);

		// NN1-2:DVT0_i  
		dvth_vtroll = -sce_output2 * Theta_SCE * (vbi - phist); 
		// NN1-3:ETA0_i  
		dvth_dibl = -sce_output3 * Theta_DIBL * vdsx + (DVTP0_i * pow(vdsx + 0.01, DVTP1_i));
		dvth_rsce = K1RSCE_i * Theta_RSCE * sqrt(phist);
		dvth_all = dvth_vtroll + dvth_dibl + dvth_rsce + DVTSHIFT;

		deltaPhi = PHIG - EASUB;
		vgsfb = vgs - deltaPhi;
		vgsfbeff = vgsfb - dvth_all;
		//************************************   Short Channel Effect Ends ****************************************************//

		//************************************   Core model calculation at source ****************************************************//
		vch = dvch_qm;
		T4 = pow(-qdep, (2.0 / 3));

		T0 = -qdep + vth_fixed_factor_Sub + QMFACTORCVfinal * T4;
		T1 = -qdep + vth_fixed_factor_SI;

		T2 = (vgsfbeff - vch) / nVtm;
		F0 = -T2 + T1;
		T3 = 0.5 * (T2 - T0);
		qm = `lexp(T3);

		T7 = ln(1.0 + qm);
		qm = 2.0 * (1.0 - sqrt(1.0 + T7 * T7));
		T8 = (qm * ALPHA_UFCM + qdep) * rc;
		T4 = T8 / (exp(T8) - T8 - 1.0);
		T5 = T8 * T4;
		qm_ln = ln(-(qm + qdep));
		e0 = F0 - qm + `lln(-qm) + `lln(T5) + QMFACTORCVfinal * exp((2.0 / 3) * qm_ln);
		e1 = -1.0 + 1.0 / qm + (2.0 / T8 - T4 - 1.0) * rc - 2 / 3 * QMFACTORCVfinal * exp(-(1.0 / 3) * qm_ln);
		e2 = -1.0 / (qm * qm) - (2.0 / 9.0) * QMFACTORCVfinal * exp(-(4.0 / 3) * qm_ln);
		qm = qm - (e0 / e1) * (1.0 + (e0 * e2) / (2.0 * e1 * e1));
		T8 = (qm * ALPHA_UFCM + qdep) * rc;
		T4 = T8 / (`lexp(T8) - T8 - 1.0);
		T5 = T8 * T4;
		qm_ln = ln(-(qm + qdep));
		e0 = F0 - qm + `lln(-qm) + `lln(T5) + QMFACTORCVfinal * exp((2.0 / 3) * qm_ln);
		e1 = -1.0 + 1.0 / qm + (2.0 / T8 - T4 - 1.0) * rc - (2.0 / 3) * QMFACTORCVfinal * exp(-(1.0 / 3) * qm_ln);
		e2 = -1.0 / (qm * qm) - (2.0 / 9.0) * QMFACTORCVfinal * exp(-(4.0 / 3) * qm_ln);
		qm = qm - (e0 / e1) * (1.0 + (e0 * e2) / (2.0 * e1 * e1));

		qis = -qm * nVtm;



		///   Drain-to-source saturation voltage
		eta_mu = 0.5 * ETAMOB_i;
		//eta_mu_cv = 0.5;
		// NN5-1  
		eta_mu_cv = 0.5 * cv_output1;
		EeffFactor = 1.0e-8 / (epsratio * EOT);
		Eeffs = EeffFactor * (qbs + eta_mu * qis);
		qb0 = 1.0e-2 / cox;
		T2 = pow((0.5 * (1.0 + qis / qb0)), UCS_t);
		T3 = pow(Eeffs, EU_i);
		T3 = UA_i * T3 + UD_i / T2;
		Dmobs = 1.0 + T3;
		Dmobs = `smoothminx(Dmobs, 1.0, DMOBCLAMP);
		Dmobs = Dmobs / U0MULT;
		VSAT_a = VSAT;
		// NN2-6
		VSAT_a = VSAT_a * clm_output6;
		Esat = 2.0 * VSAT_a / U0_i * Dmobs;
		EsatL = Esat * Lg;
		KSATIV_a = KSATIV;
		// NN2-7
		KSATIV_a = KSATIV_a * clm_output7;
		T6 = KSATIV_a * (qis + 2.0 * Vtm);
		Vdsat = EsatL * T6 / (EsatL + T6);
		Vdsat = `hypsmooth((Vdsat - 1.0e-3), 1.0e-5) + 1.0e-3;
		MEXP_a = MEXP;
		// NN2-8
		MEXP_a = MEXP_a * clm_output8;
		T7 = pow(((vds / Vdsat) + 1e-6), MEXP_a);
		T8 = pow((1.0 + T7), (1 / MEXP_a));
		Vdseff = min((vds / T8), vds);

		//************************************   Core model calculation at drain ****************************************************//
		vch = Vdseff + dvch_qm;
		T2 = pow((-qdep), (2.0 / 3));

		T0 = -qdep + vth_fixed_factor_Sub + QMFACTORCVfinal * T2;
		T1 = -qdep + vth_fixed_factor_SI;

		T2 = (vgsfbeff - vch) / nVtm;
		F0 = -T2 + T1;
		T3 = (T2 - T0) * 0.5;
		qm = `lexp(T3);

		T7 = ln(1.0 + qm);
		qm = 2.0 * (1.0 - sqrt(1.0 + T7 * T7));
		T8 = (qm * ALPHA_UFCM + qdep) * rc;
		T4 = T8 / (`lexp(T8) - T8 - 1.0);
		T5 = T8 * T4;
		qm_ln = ln(-(qm + qdep));
		e0 = F0 - qm + `lln(-qm) + `lln(T5) + QMFACTORCVfinal * exp((2.0 / 3) * qm_ln);
		e1 = -1.0 + (1.0 / qm) + (2.0 / T8 - T4 - 1.0) * rc - (2.0 / 3) * QMFACTORCVfinal * exp(-(1.0 / 3) * qm_ln);
		e2 = -1.0 / (qm * qm) - (2.0 / 9.0) * QMFACTORCVfinal * exp(-(4.0 / 3) * qm_ln);
		qm = qm - (e0 / e1) * (1.0 + (e0 * e2) / (2.0 * e1 * e1));
		T8 = (qm * ALPHA_UFCM + qdep) * rc;
		T4 = T8 / (`lexp(T8) - T8 - 1.0);
		T5 = T8 * T4;
		qm_ln = ln(-(qm + qdep));
		e0 = F0 - qm + `lln(-qm) + `lln(T5) + QMFACTORCVfinal * exp((2.0 / 3) * qm_ln);
		e1 = -1.0 + (1.0 / qm) + (2.0 / T8 - T4 - 1.0) * rc - (2.0 / 3) * QMFACTORCVfinal * exp(-(1.0 / 3) * qm_ln);
		e2 = -1.0 / (qm * qm) - (2.0 / 9.0) * QMFACTORCVfinal * exp(-(4.0 / 3) * qm_ln);
		qm = qm - (e0 / e1) * (1.0 + (e0 * e2) / (2.0 * e1 * e1));

		qid = -qm * nVtm;



		//************************************   Quasi-static I-V model ****************************************************//
		qia = 0.5 * (qis + qid);
		dqi = qis - qid;
		etaiv = q0 / (q0 + qia);
		ids0_ov_dqi = qia + (2.0 - etaiv) * nVtm;
		ids0 = ids0_ov_dqi * dqi;

		//************************************   Channel length modulation ****************************************************//
		Leff = Lg;
		LeffCV = Lg;

		DROUT_i = DROUT;
		// NN2-9
		DROUT_i = DROUT_i * clm_output9;  
		tmp = DROUT_i * Leff / scl + 1.0e-6;

		PDIBL1_a = PDIBL1;
		// NN2-10
		PDIBL1_a = PDIBL1_a * clm_output10;  
		PDIBL2_a = PDIBL2;
		// NN2-11
		PDIBL2_a = PDIBL2_a * clm_output11;  

		DIBLfactor = PDIBL1_a * exp(-tmp) + PDIBL2_a;

		PVAG_i = PVAG;
		// NN2-12
		PVAG_i = PVAG_i * clm_output12;  
		PVAGfactor = 1.0 + PVAG_i * qia / EsatL;
		diffVds = vds - Vdseff;
		Vgst2Vtm = qia + 2.0 * Vtm;
		T1 = Vgst2Vtm;
		T3 = T1 / (Vdsat + T1);
		VaDIBL = T1 / DIBLfactor * T3 * PVAGfactor;
		Moc = 1.0 + diffVds / VaDIBL;
		// NN2-1:PCLM_i 		NN2-5:PCLMG
		T1 = clm_output1 + clm_output5 * qia; 
		Mclm = 1.0 + T1 * `lln(1.0 + (vds - Vdseff) / T1 / (Vdsat + EsatL));
		Moc = Moc * Mclm;

		//************************************   Toxeff model for quantum mechanical effects ****************************************************//
		T4 = qia / QM0;
		T5 = 1.0 + pow(T4, PQM);
		Tcen = Tcen0 / T5;
		// NN3-2  NN3-3 
		//coxeff = 1.0 / (1.0 / (cox * EOT / (TOXP * qua_output2)) + Tcen * QMTCENCV_i * qua_output3 / epssub);
		coxeff = 1.0 / (1.0 / (cox * EOT / (TOXP * qua_output2)) + Tcen * qua_output3 / epssub);

		// Drain current
		cox = Cins / Weff_UFCM;
		beta = U0_i * cox * Weff_UFCM / Lg;


		//************************************   Mobility degradation ****************************************************//
		qia2 = 0.5 * (qis + qid);
		Eeffm = EeffFactor * (qbs + eta_mu * qia2);
		T2 = pow(0.5 * (1.0 + qia2 / qb0), UCS_t);
		T0 = pow(Eeffm, EU_i);
		T3 = UA_i * T0 + UD_i / T2;
		Dmob = 1.0 + T3;
		Dmob = `smoothminx(Dmob, 1.0, DMOBCLAMP);
		Dmob = Dmob / U0MULT;
		ueff = U0_i / Dmob; 

		//************************************   Mobility degradation for C-V ****************************************************//
		Eeffm_cv = EeffFactor * (qbs + eta_mu_cv * qia2);
		T3 = UA_i * pow(Eeffm_cv, EU_i) + UD_i / T2;
		Dmob_cv = 1.0 + T3;
		Dmob_cv = `smoothminx(Dmob_cv, 1.0, DMOBCLAMP);
		Dmob_cv = Dmob_cv / U0MULT;

		//************************************   Current degradation due to velocity saturation ****************************************************//
		VSAT1_a = VSAT1;		
		// NN2-13
		VSAT1_a = VSAT1_a * clm_output13;
		Esat1 = 2.0 * VSAT1_a / ueff;
		Esat1L = Esat1 * Lg;
		// NN2-2: PSAT_i
		T0 = `lexp(clm_output2 * `lln(dqi / Esat1L)); 
		T1 = 1.0 / clm_output2; 
		// NN2-3: DELTAVSAT_i
		Ta = 1.0 + `lexp(T1 * `lln(clm_output3));  
		Dvsat = (1.0 + `lexp(T1 * `lln(clm_output3 + T0))) / Ta; 
		// NN2-4: PTWG_a
		Dvsat = Dvsat + 0.5 * clm_output4 * qia * dqi * dqi;

		//************************************   Non-saturation effect ****************************************************//
		T0 = A1_t + A2_t / (qia + 2.0 * nVtm);
		T1 = T0 * dqi * dqi;
		T2 = T1 + 1.0 - 0.001;
		T3 = -1.0 + 0.5 * (T2 + sqrt(T2 * T2 + 0.004));
		Nsat = 0.5 * (1.0 + sqrt(1.0 + T3));
		Dvsat = Dvsat * Nsat;
		Dvsat = `smoothminx(Dvsat, 1.0, DVSATCLAMP);

		//************************************   Velocity saturation for C-V ****************************************************//

		// NN5-2: PTWG_a
		EsatCV = 2.0 * VSATCV_t * cv_output2 * Dmob_cv / U0_i; 
		EsatCVL = EsatCV * LeffCV;
		// NN5-3: PSATCV_i
		T0 = pow((dqi / EsatCVL), cv_output3);
		T1 = 1.0 / cv_output3;
		// NN5-4: DELTAVSATCV_i
		Ta = 1.0 + pow(cv_output4, T1);
		DvsatCV = (1.0 + pow((cv_output4 + T0), T1)) / Ta;
		// NN5-5: PCLMCV_i
		MclmCV = 1.0 + cv_output5 * `lln(1.0 + (vds - Vdseff) / cv_output5 / (Vdsat + EsatCVL));




		//************************************  GIDL ****************************************************//
		T0 = epsratio * EOT;
		T1 = (-(vgs - vds)) / T0;
		T1 = `hypsmooth(T1, 1.0e-2);
		// NN3-4: BGIDL_i
		T2 = 10 * pow(10.0, 8.0) * gidl_output4 / (T1 + 1.0e-3);
		T3 = pow(T1, 1);
		// NN3-4: AGIDL_i
		T6 = 6.05 * pow(10.0, -12.0) * Weff0 * T3 * `lexp(-T2) * vds * 4 * gidl_output5;
		igidl = T6;
		//igidl_tmp1 = T2;
		//igidl_tmp2 = T3;



		ids = NF * beta * ids0 * Moc / (Dmob * Dvsat) + igidl;
		
		ids_tmp = beta * ids0 * Moc / (Dmob * Dvsat);

		//************************************   Quasi-static C-V model ****************************************************//
		T11 = (2.0 * qia + nVtm) / DvsatCV;
		qg = qia + dqi * dqi / (6.0 * T11);
		qd = -0.5 * (qia - (dqi / 6.0) * (1.0 - (dqi / T11) * (1.0 + dqi / (5.0 * T11))));

		//  CLM in qg and qd
		inv_MclmCV = 1.0 / MclmCV;
		qg = inv_MclmCV * qg + (MclmCV - 1.0) * qid;
		qd = inv_MclmCV * inv_MclmCV * qd + 0.5 * (MclmCV - inv_MclmCV) * qid;
		//$strobe("qg=",qg);
		//$strobe("qd=",qd);
		qs = -qg - qd;
		T6 = WeffCV0 * LeffCV * coxeff;
		qg = T6 * qg;
		qd = T6 * qd;
		qs = T6 * qs;

		//  Bias-dependent overlap capacitances
		CGSO_i = 0.3 * TFIN * cox * cv_output10;
		CGDO_i = 0.3 * TFIN * cox * cv_output13;

		T1 = WeffCV0 * devsign;
		T2 = devsign * vgs;
		T0 = T2 - vfbsdcv + DELTA_1;
		vgs_overlap = 0.5 * (T0 - sqrt(T0 * T0 + 4.0 * DELTA_1));
		qgs_ov = T1 * (CGSL_i * cv_output8 * (T2 - vfbsdcv - vgs_overlap - 0.5 * cv_output9 * (sqrt(1.0 - 4.0 * vgs_overlap / cv_output9) - 1.0)) + CGSO_i * T2);

		T2 = devsign * (vgs - vds);
		T0 = T2 - vfbsdcv + DELTA_1;
		vgd_overlap = 0.5 * (T0 - sqrt(T0 * T0 + 4.0 * DELTA_1));
		qgd_ov = T1 * (CGSL_i * cv_output11 * (T2 - vfbsdcv - vgd_overlap - 0.5 * cv_output12 * (sqrt(1.0 - 4.0 * vgd_overlap / cv_output12) - 1.0)) + CGDO_i * T2);

		T1 = WeffCV0;
		// NN5-6: CFS_i
		qgs_fr = T1 * CFS_i * cv_output6 * vgs;
		// NN5-7: CFD_i
		qgd_fr = T1 * CFD_i * cv_output7 * (vgs - vds);

		qgs_parasitic = qgs_ov + qgs_fr;
		qgd_parasitic = qgd_ov + qgd_fr;

		QG = type * (devsign * qg + qgs_parasitic + qgd_parasitic);
		QD = type * (devsign * qd - qgd_parasitic);
		QS = type * (devsign * qs - qgs_parasitic);

    GM = ddx(ids, V(G));
    GDS = ddx(ids, V(D));

    CGG = ddx(QG, V(G));
    CGD = ddx(QG, V(D));
    CGS = ddx(QG, V(S));
    CDG = ddx(QD, V(G));
    CDD = ddx(QD, V(D));
    CDS = ddx(QD, V(S));
    CSG = ddx(QS, V(G));
    CSD = ddx(QS, V(D));
    CSS = ddx(QS, V(S));




//****** dc current ******//
	   if (mode > 0.0)
	      I(D, S) <+ type * ids;
	   else
	      I(D, S) <+ -type * ids;

	   //****charging current******//
	   //I(gate, source)   <+ ddt(QG);
	   //I(drain, source)  <+ ddt(QD); 

		tmp1_pku = 		sce_output1;
		tmp2_pku = 		sce_output2;
		tmp3_pku = 		sce_output3;
		tmp4_pku = 		sce_output4;
		tmp5_pku = 		sce_output5;

//******Beginning of the model******//


NBODY_CV = 5.0e21;             //###########1111
NSD_CV = 1.0e26;				//###########1111
PHIG_CV = 4.37;                 //###########1111
CFS_i_CV = 1e-10;               //###########1111
CFD_i_CV = 1e-10;              //###########1111






   //****the calculation starts****//

			Lg = L + XL;
	   //****** input normalizations ******//
	 		//tgaa_nor = ((TGAA - tgaamin) / (tgaamax - tgaamin)) * (netmax-netmin) + netmin;
	 		//w_nor    = ((WGAA - wgaamin) / (wgaamax - wgaamin)) * (netmax-netmin) + netmin;
	 		w_nor    = ((WGAA - wgaamin) / (wgaamax - wgaamin)) * (netmax-netmin) + netmin;//###########1111
			tgaa_nor =-1;	 			//###########1111
	 		l_nor    = ((L - lgaamin) / (lgaamax - lgaamin)) * (netmax-netmin) + netmin;//###########1111




	   //****** calculation starts NN1 SCE Model******//
	   //***1st layer***//
      neuronsce1_1_in  = nnscew1_1_1_cap*w_nor +nnscew1_1_2_cap*l_nor +nnsceb1_1_cap;
   	  neuronsce1_2_in  = nnscew1_2_1_cap*w_nor +nnscew1_2_2_cap*l_nor +nnsceb1_2_cap;
	   	neuronsce1_1_out =Sigmoid(neuronsce1_1_in);
      neuronsce1_2_out =Sigmoid(neuronsce1_2_in);
	   //***2nd layer***//
      neuronsce2_1_in  = nnscew2_1_1_cap*neuronsce1_1_out + nnscew2_1_2_cap*neuronsce1_2_out + nnsceb2_1_cap;
   	  neuronsce2_2_in  = nnscew2_2_1_cap*neuronsce1_1_out + nnscew2_2_2_cap*neuronsce1_2_out + nnsceb2_2_cap;
	   	neuronsce2_1_out =Sigmoid(neuronsce2_1_in);
      neuronsce2_2_out =Sigmoid(neuronsce2_2_in);
	   //***Output layer***//
      neuronsce3_1_in  = nnscew3_1_1_cap*neuronsce2_1_out + nnscew3_1_2_cap*neuronsce2_2_out + nnsceb3_1_cap;
   	  neuronsce3_2_in  = nnscew3_2_1_cap*neuronsce2_1_out + nnscew3_2_2_cap*neuronsce2_2_out + nnsceb3_2_cap;
      neuronsce3_3_in  = nnscew3_3_1_cap*neuronsce2_1_out + nnscew3_3_2_cap*neuronsce2_2_out + nnsceb3_3_cap;
   	  neuronsce3_4_in  = nnscew3_4_1_cap*neuronsce2_1_out + nnscew3_4_2_cap*neuronsce2_2_out + nnsceb3_4_cap;
      neuronsce3_5_in  = nnscew3_5_1_cap*neuronsce2_1_out + nnscew3_5_2_cap*neuronsce2_2_out + nnsceb3_5_cap;
	   	neuronsce3_1_out =Sigmoid(neuronsce3_1_in);
      neuronsce3_2_out =Sigmoid(neuronsce3_2_in);
	   	neuronsce3_3_out =Sigmoid(neuronsce3_3_in);
      neuronsce3_4_out =Sigmoid(neuronsce3_4_in);			
	   	neuronsce3_5_out =Sigmoid(neuronsce3_5_in);
			
			sce_output1 = 5 * neuronsce3_1_out;	
			sce_output2 = 5 * neuronsce3_2_out;	
			sce_output3 = 5 * neuronsce3_3_out;	
			sce_output4 = 5 * neuronsce3_4_out;	
			sce_output5 = 5 * neuronsce3_5_out;	
	   //****** calculation ends NN1 SCE Model******//

	   //****** calculation starts NN2 CLM Verlocity Saturation Model******//
	   //***1st layer***//
      neuronclm1_1_in  = nnclmw1_1_1_cap*w_nor +nnclmw1_1_2_cap*l_nor +nnclmb1_1_cap;
   	  neuronclm1_2_in  = nnclmw1_2_1_cap*w_nor +nnclmw1_2_2_cap*l_nor +nnclmb1_2_cap;
      neuronclm1_3_in  = nnclmw1_3_1_cap*w_nor +nnclmw1_3_2_cap*l_nor +nnclmb1_3_cap;
   	  neuronclm1_4_in  = nnclmw1_4_1_cap*w_nor +nnclmw1_4_2_cap*l_nor +nnclmb1_4_cap;
	   	neuronclm1_1_out =Sigmoid(neuronclm1_1_in);
      neuronclm1_2_out =Sigmoid(neuronclm1_2_in);
	   	neuronclm1_3_out =Sigmoid(neuronclm1_3_in);
      neuronclm1_4_out =Sigmoid(neuronclm1_4_in);
	   //***2nd layer***//
      neuronclm2_1_in  = nnclmw2_1_1_cap*neuronclm1_1_out + nnclmw2_1_2_cap*neuronclm1_2_out + nnclmw2_1_3_cap*neuronclm1_3_out + nnclmw2_1_4_cap*neuronclm1_4_out + nnclmb2_1_cap;
   	  neuronclm2_2_in  = nnclmw2_2_1_cap*neuronclm1_1_out + nnclmw2_2_2_cap*neuronclm1_2_out + nnclmw2_2_3_cap*neuronclm1_3_out + nnclmw2_2_4_cap*neuronclm1_4_out + nnclmb2_2_cap;
      neuronclm2_3_in  = nnclmw2_3_1_cap*neuronclm1_1_out + nnclmw2_3_2_cap*neuronclm1_2_out + nnclmw2_3_3_cap*neuronclm1_3_out + nnclmw2_3_4_cap*neuronclm1_4_out + nnclmb2_3_cap;
   	  neuronclm2_4_in  = nnclmw2_4_1_cap*neuronclm1_1_out + nnclmw2_4_2_cap*neuronclm1_2_out + nnclmw2_4_3_cap*neuronclm1_3_out + nnclmw2_4_4_cap*neuronclm1_4_out + nnclmb2_4_cap;
	   	neuronclm2_1_out =Sigmoid(neuronclm2_1_in);
      neuronclm2_2_out =Sigmoid(neuronclm2_2_in);
	   	neuronclm2_3_out =Sigmoid(neuronclm2_3_in);
      neuronclm2_4_out =Sigmoid(neuronclm2_4_in);
	   //***Output layer***//
      neuronclm3_1_in  = nnclmw3_1_1_cap*neuronclm2_1_out + nnclmw3_1_2_cap*neuronclm2_2_out + nnclmw3_1_3_cap*neuronclm2_3_out + nnclmw3_1_4_cap*neuronclm2_4_out + nnclmb3_1_cap;
      neuronclm3_2_in  = nnclmw3_2_1_cap*neuronclm2_1_out + nnclmw3_2_2_cap*neuronclm2_2_out + nnclmw3_2_3_cap*neuronclm2_3_out + nnclmw3_2_4_cap*neuronclm2_4_out + nnclmb3_2_cap;
      neuronclm3_3_in  = nnclmw3_3_1_cap*neuronclm2_1_out + nnclmw3_3_2_cap*neuronclm2_2_out + nnclmw3_3_3_cap*neuronclm2_3_out + nnclmw3_3_4_cap*neuronclm2_4_out + nnclmb3_3_cap;
      neuronclm3_4_in  = nnclmw3_4_1_cap*neuronclm2_1_out + nnclmw3_4_2_cap*neuronclm2_2_out + nnclmw3_4_3_cap*neuronclm2_3_out + nnclmw3_4_4_cap*neuronclm2_4_out + nnclmb3_4_cap;
      neuronclm3_5_in  = nnclmw3_5_1_cap*neuronclm2_1_out + nnclmw3_5_2_cap*neuronclm2_2_out + nnclmw3_5_3_cap*neuronclm2_3_out + nnclmw3_5_4_cap*neuronclm2_4_out + nnclmb3_5_cap;
      neuronclm3_6_in  = nnclmw3_6_1_cap*neuronclm2_1_out + nnclmw3_6_2_cap*neuronclm2_2_out + nnclmw3_6_3_cap*neuronclm2_3_out + nnclmw3_6_4_cap*neuronclm2_4_out + nnclmb3_6_cap;
      neuronclm3_7_in  = nnclmw3_7_1_cap*neuronclm2_1_out + nnclmw3_7_2_cap*neuronclm2_2_out + nnclmw3_7_3_cap*neuronclm2_3_out + nnclmw3_7_4_cap*neuronclm2_4_out + nnclmb3_7_cap;
      neuronclm3_8_in  = nnclmw3_8_1_cap*neuronclm2_1_out + nnclmw3_8_2_cap*neuronclm2_2_out + nnclmw3_8_3_cap*neuronclm2_3_out + nnclmw3_8_4_cap*neuronclm2_4_out + nnclmb3_8_cap;
      neuronclm3_9_in  = nnclmw3_9_1_cap*neuronclm2_1_out + nnclmw3_9_2_cap*neuronclm2_2_out + nnclmw3_9_3_cap*neuronclm2_3_out + nnclmw3_9_4_cap*neuronclm2_4_out + nnclmb3_9_cap;
      neuronclm3_10_in  = nnclmw3_10_1_cap*neuronclm2_1_out + nnclmw3_10_2_cap*neuronclm2_2_out + nnclmw3_10_3_cap*neuronclm2_3_out + nnclmw3_10_4_cap*neuronclm2_4_out + nnclmb3_10_cap;
      neuronclm3_11_in  = nnclmw3_11_1_cap*neuronclm2_1_out + nnclmw3_11_2_cap*neuronclm2_2_out + nnclmw3_11_3_cap*neuronclm2_3_out + nnclmw3_11_4_cap*neuronclm2_4_out + nnclmb3_11_cap;
      neuronclm3_12_in  = nnclmw3_12_1_cap*neuronclm2_1_out + nnclmw3_12_2_cap*neuronclm2_2_out + nnclmw3_12_3_cap*neuronclm2_3_out + nnclmw3_12_4_cap*neuronclm2_4_out + nnclmb3_12_cap;
      neuronclm3_13_in  = nnclmw3_13_1_cap*neuronclm2_1_out + nnclmw3_13_2_cap*neuronclm2_2_out + nnclmw3_13_3_cap*neuronclm2_3_out + nnclmw3_13_4_cap*neuronclm2_4_out + nnclmb3_13_cap;
	   	neuronclm3_1_out =Sigmoid(neuronclm3_1_in);
      neuronclm3_2_out =Sigmoid(neuronclm3_2_in);
	   	neuronclm3_3_out =Sigmoid(neuronclm3_3_in);
      neuronclm3_4_out =Sigmoid(neuronclm3_4_in);			
	   	neuronclm3_5_out =Sigmoid(neuronclm3_5_in);
	   	neuronclm3_6_out =Sigmoid(neuronclm3_6_in);
      neuronclm3_7_out =Sigmoid(neuronclm3_7_in);
	   	neuronclm3_8_out =Sigmoid(neuronclm3_8_in);
      neuronclm3_9_out =Sigmoid(neuronclm3_9_in);			
	   	neuronclm3_10_out =Sigmoid(neuronclm3_10_in);
	   	neuronclm3_11_out =Sigmoid(neuronclm3_11_in);
      neuronclm3_12_out =Sigmoid(neuronclm3_12_in);
	   	neuronclm3_13_out =Sigmoid(neuronclm3_13_in);
			
			clm_output1 = 5 * neuronclm3_1_out;	
			clm_output2 = 5 * neuronclm3_2_out;	
			clm_output3 = 5 * neuronclm3_3_out;	
			clm_output4 = 5 * neuronclm3_4_out;	
			clm_output5 = 5 * neuronclm3_5_out;	
			clm_output6 = 5 * neuronclm3_6_out;	
			clm_output7 = 5 * neuronclm3_7_out;	
			clm_output8 = 5 * neuronclm3_8_out;	
			clm_output9 = 5 * neuronclm3_9_out;	
			clm_output10 = 5 * neuronclm3_10_out;	
			clm_output11 = 5 * neuronclm3_11_out;	
			clm_output12 = 5 * neuronclm3_12_out;	
			clm_output13 = 5 * neuronclm3_13_out;	
	   //****** calculation ends NN2 CLM Verlocity Saturation Model******//

	   //****** calculation starts NN3 Quantum Model******//
	   //***1st layer***//
			neuronqua1_1_in = nnquaw1_1_1_cap*l_nor + nnquaw1_1_2_cap*w_nor + nnquab1_1_cap;
			neuronqua1_2_in = nnquaw1_2_1_cap*l_nor + nnquaw1_2_2_cap*w_nor + nnquab1_2_cap;
			neuronqua1_3_in = nnquaw1_3_1_cap*l_nor + nnquaw1_3_2_cap*w_nor + nnquab1_3_cap;
			neuronqua1_1_out = Sigmoid(neuronqua1_1_in);
			neuronqua1_2_out = Sigmoid(neuronqua1_2_in);
			neuronqua1_3_out = Sigmoid(neuronqua1_3_in);
	   //***2nd layer***//
			neuronqua2_1_in = nnquaw2_1_1_cap*neuronqua1_1_out + nnquaw2_1_2_cap*neuronqua1_2_out + nnquaw2_1_3_cap*neuronqua1_3_out + nnquab2_1_cap;
			neuronqua2_2_in = nnquaw2_2_1_cap*neuronqua1_1_out + nnquaw2_2_2_cap*neuronqua1_2_out + nnquaw2_2_3_cap*neuronqua1_3_out + nnquab2_2_cap;
			neuronqua2_3_in = nnquaw2_3_1_cap*neuronqua1_1_out + nnquaw2_3_2_cap*neuronqua1_2_out + nnquaw2_3_3_cap*neuronqua1_3_out + nnquab2_3_cap;
			neuronqua2_1_out = Sigmoid(neuronqua2_1_in);
			neuronqua2_2_out = Sigmoid(neuronqua2_2_in);
			neuronqua2_3_out = Sigmoid(neuronqua2_3_in);
	   //***Output layer***//
			neuronqua3_1_in = nnquaw3_1_1_cap*neuronqua2_1_out + nnquaw3_1_2_cap*neuronqua2_2_out + nnquaw3_1_3_cap*neuronqua2_3_out + nnquab3_1_cap;
			neuronqua3_2_in = nnquaw3_2_1_cap*neuronqua2_1_out + nnquaw3_2_2_cap*neuronqua2_2_out + nnquaw3_2_3_cap*neuronqua2_3_out + nnquab3_2_cap;
			neuronqua3_3_in = nnquaw3_3_1_cap*neuronqua2_1_out + nnquaw3_3_2_cap*neuronqua2_2_out + nnquaw3_3_3_cap*neuronqua2_3_out + nnquab3_3_cap;
			neuronqua3_1_out = Sigmoid(neuronqua3_1_in);
			neuronqua3_2_out = Sigmoid(neuronqua3_2_in);
			neuronqua3_3_out = Sigmoid(neuronqua3_3_in);

			qua_output1 = 5 * neuronqua3_1_out;
			qua_output2 = 5 * neuronqua3_2_out;
			qua_output3 = 5 * neuronqua3_3_out;
	   //****** calculation ends NN3 Quantum Model******//

	   //****** calculation starts NN4 Mobility Model******//
	   //***1st layer***//
			neuronmob1_1_in = nnmobw1_1_1_cap*tgaa_nor + nnmobw1_1_2_cap*w_nor + nnmobw1_1_3_cap*l_nor + nnmobb1_1_cap;
			neuronmob1_2_in = nnmobw1_2_1_cap*tgaa_nor + nnmobw1_2_2_cap*w_nor + nnmobw1_2_3_cap*l_nor + nnmobb1_2_cap;
			neuronmob1_1_out = Sigmoid(neuronmob1_1_in);
			neuronmob1_2_out = Sigmoid(neuronmob1_2_in);
	   //***2nd layer***//
			neuronmob2_1_in = nnmobw2_1_1_cap*neuronmob1_1_out + nnmobw2_1_2_cap*neuronmob1_2_out + nnmobb2_1_cap;
			neuronmob2_2_in = nnmobw2_2_1_cap*neuronmob1_1_out + nnmobw2_2_2_cap*neuronmob1_2_out + nnmobb2_2_cap;
			neuronmob2_1_out = Sigmoid(neuronmob2_1_in);
			neuronmob2_2_out = Sigmoid(neuronmob2_2_in);
	   //***Output layer***//
			neuronmob3_1_in = nnmobw3_1_1_cap*neuronmob2_1_out + nnmobw3_1_2_cap*neuronmob2_2_out + nnmobb3_1_cap;
			neuronmob3_2_in = nnmobw3_2_1_cap*neuronmob2_1_out + nnmobw3_2_2_cap*neuronmob2_2_out + nnmobb3_2_cap;
			neuronmob3_3_in = nnmobw3_3_1_cap*neuronmob2_1_out + nnmobw3_3_2_cap*neuronmob2_2_out + nnmobb3_3_cap;
			neuronmob3_4_in = nnmobw3_4_1_cap*neuronmob2_1_out + nnmobw3_4_2_cap*neuronmob2_2_out + nnmobb3_4_cap;
			neuronmob3_5_in = nnmobw3_5_1_cap*neuronmob2_1_out + nnmobw3_5_2_cap*neuronmob2_2_out + nnmobb3_5_cap;
			neuronmob3_1_out = Sigmoid(neuronmob3_1_in);
			neuronmob3_2_out = Sigmoid(neuronmob3_2_in);
			neuronmob3_3_out = Sigmoid(neuronmob3_3_in);
			neuronmob3_4_out = Sigmoid(neuronmob3_4_in);
			neuronmob3_5_out = Sigmoid(neuronmob3_5_in);

			mob_output1 = 5 * neuronmob3_1_out;	
			mob_output2 = 5 * neuronmob3_2_out;	
			mob_output3 = 5 * neuronmob3_3_out;	
			mob_output4 = 5 * neuronmob3_4_out;	
			mob_output5 = 5 * neuronmob3_5_out;	
	   //****** calculation ends NN4 Mobility Model******//

	   //****** calculation starts NN5 CV Model******//
	   //***1st layer***//
			neuroncv1_1_in = nncvw1_1_1_cap*tgaa_nor + nncvw1_1_2_cap*w_nor + nncvw1_1_3_cap*l_nor + nncvb1_1_cap;
			neuroncv1_2_in = nncvw1_2_1_cap*tgaa_nor + nncvw1_2_2_cap*w_nor + nncvw1_2_3_cap*l_nor + nncvb1_2_cap;
			neuroncv1_3_in = nncvw1_3_1_cap*tgaa_nor + nncvw1_3_2_cap*w_nor + nncvw1_3_3_cap*l_nor + nncvb1_3_cap;
			neuroncv1_4_in = nncvw1_4_1_cap*tgaa_nor + nncvw1_4_2_cap*w_nor + nncvw1_4_3_cap*l_nor + nncvb1_4_cap;
			neuroncv1_1_out = Sigmoid(neuroncv1_1_in);
			neuroncv1_2_out = Sigmoid(neuroncv1_2_in);
			neuroncv1_3_out = Sigmoid(neuroncv1_3_in);
			neuroncv1_4_out = Sigmoid(neuroncv1_4_in);
	   //***2nd layer***//
			neuroncv2_1_in = nncvw2_1_1_cap*neuroncv1_1_out + nncvw2_1_2_cap*neuroncv1_2_out + nncvw2_1_3_cap*neuroncv1_3_out + nncvw2_1_4_cap*neuroncv1_4_out + nncvb2_1_cap;
			neuroncv2_2_in = nncvw2_2_1_cap*neuroncv1_1_out + nncvw2_2_2_cap*neuroncv1_2_out + nncvw2_2_3_cap*neuroncv1_3_out + nncvw2_2_4_cap*neuroncv1_4_out + nncvb2_2_cap;
			neuroncv2_3_in = nncvw2_3_1_cap*neuroncv1_1_out + nncvw2_3_2_cap*neuroncv1_2_out + nncvw2_3_3_cap*neuroncv1_3_out + nncvw2_3_4_cap*neuroncv1_4_out + nncvb2_3_cap;
			neuroncv2_4_in = nncvw2_4_1_cap*neuroncv1_1_out + nncvw2_4_2_cap*neuroncv1_2_out + nncvw2_4_3_cap*neuroncv1_3_out + nncvw2_4_4_cap*neuroncv1_4_out + nncvb2_4_cap;
			neuroncv2_1_out = Sigmoid(neuroncv2_1_in);
			neuroncv2_2_out = Sigmoid(neuroncv2_2_in);
			neuroncv2_3_out = Sigmoid(neuroncv2_3_in);
			neuroncv2_4_out = Sigmoid(neuroncv2_4_in);
	   //***Output layer***//
			neuroncv3_1_in = nncvw3_1_1_cap*neuroncv2_1_out + nncvw3_1_2_cap*neuroncv2_2_out + nncvw3_1_3_cap*neuroncv2_3_out + nncvw3_1_4_cap*neuroncv2_4_out + nncvb3_1_cap;
			neuroncv3_2_in = nncvw3_2_1_cap*neuroncv2_1_out + nncvw3_2_2_cap*neuroncv2_2_out + nncvw3_2_3_cap*neuroncv2_3_out + nncvw3_2_4_cap*neuroncv2_4_out + nncvb3_2_cap;
			neuroncv3_3_in = nncvw3_3_1_cap*neuroncv2_1_out + nncvw3_3_2_cap*neuroncv2_2_out + nncvw3_3_3_cap*neuroncv2_3_out + nncvw3_3_4_cap*neuroncv2_4_out + nncvb3_3_cap;
			neuroncv3_4_in = nncvw3_4_1_cap*neuroncv2_1_out + nncvw3_4_2_cap*neuroncv2_2_out + nncvw3_4_3_cap*neuroncv2_3_out + nncvw3_4_4_cap*neuroncv2_4_out + nncvb3_4_cap;
			neuroncv3_5_in = nncvw3_5_1_cap*neuroncv2_1_out + nncvw3_5_2_cap*neuroncv2_2_out + nncvw3_5_3_cap*neuroncv2_3_out + nncvw3_5_4_cap*neuroncv2_4_out + nncvb3_5_cap;
			neuroncv3_6_in = nncvw3_6_1_cap*neuroncv2_1_out + nncvw3_6_2_cap*neuroncv2_2_out + nncvw3_6_3_cap*neuroncv2_3_out + nncvw3_6_4_cap*neuroncv2_4_out + nncvb3_6_cap;
			neuroncv3_7_in = nncvw3_7_1_cap*neuroncv2_1_out + nncvw3_7_2_cap*neuroncv2_2_out + nncvw3_7_3_cap*neuroncv2_3_out + nncvw3_7_4_cap*neuroncv2_4_out + nncvb3_7_cap;
			neuroncv3_8_in = nncvw3_8_1_cap*neuroncv2_1_out + nncvw3_8_2_cap*neuroncv2_2_out + nncvw3_8_3_cap*neuroncv2_3_out + nncvw3_8_4_cap*neuroncv2_4_out + nncvb3_8_cap;
			neuroncv3_9_in = nncvw3_9_1_cap*neuroncv2_1_out + nncvw3_9_2_cap*neuroncv2_2_out + nncvw3_9_3_cap*neuroncv2_3_out + nncvw3_9_4_cap*neuroncv2_4_out + nncvb3_9_cap;
			neuroncv3_10_in = nncvw3_10_1_cap*neuroncv2_1_out + nncvw3_10_2_cap*neuroncv2_2_out + nncvw3_10_3_cap*neuroncv2_3_out + nncvw3_10_4_cap*neuroncv2_4_out + nncvb3_10_cap;
			neuroncv3_11_in = nncvw3_11_1_cap*neuroncv2_1_out + nncvw3_11_2_cap*neuroncv2_2_out + nncvw3_11_3_cap*neuroncv2_3_out + nncvw3_11_4_cap*neuroncv2_4_out + nncvb3_11_cap;
			neuroncv3_12_in = nncvw3_12_1_cap*neuroncv2_1_out + nncvw3_12_2_cap*neuroncv2_2_out + nncvw3_12_3_cap*neuroncv2_3_out + nncvw3_12_4_cap*neuroncv2_4_out + nncvb3_12_cap;
			neuroncv3_13_in = nncvw3_13_1_cap*neuroncv2_1_out + nncvw3_13_2_cap*neuroncv2_2_out + nncvw3_13_3_cap*neuroncv2_3_out + nncvw3_13_4_cap*neuroncv2_4_out + nncvb3_13_cap;
			neuroncv3_14_in = nncvw3_14_1_cap*neuroncv2_1_out + nncvw3_14_2_cap*neuroncv2_2_out + nncvw3_14_3_cap*neuroncv2_3_out + nncvw3_14_4_cap*neuroncv2_4_out + nncvb3_14_cap;
			neuroncv3_15_in = nncvw3_15_1_cap*neuroncv2_1_out + nncvw3_15_2_cap*neuroncv2_2_out + nncvw3_15_3_cap*neuroncv2_3_out + nncvw3_15_4_cap*neuroncv2_4_out + nncvb3_15_cap;
			neuroncv3_1_out = Sigmoid(neuroncv3_1_in);
			neuroncv3_2_out = Sigmoid(neuroncv3_2_in);
			neuroncv3_3_out = Sigmoid(neuroncv3_3_in);
			neuroncv3_4_out = Sigmoid(neuroncv3_4_in);
			neuroncv3_5_out = Sigmoid(neuroncv3_5_in);
			neuroncv3_6_out = Sigmoid(neuroncv3_6_in);
			neuroncv3_7_out = Sigmoid(neuroncv3_7_in);
			neuroncv3_8_out = Sigmoid(neuroncv3_8_in);
			neuroncv3_9_out = Sigmoid(neuroncv3_9_in);
			neuroncv3_10_out = Sigmoid(neuroncv3_10_in);
			neuroncv3_11_out = Sigmoid(neuroncv3_11_in);
			neuroncv3_12_out = Sigmoid(neuroncv3_12_in);
			neuroncv3_13_out = Sigmoid(neuroncv3_13_in);
			neuroncv3_14_out = Sigmoid(neuroncv3_14_in);
			neuroncv3_15_out = Sigmoid(neuroncv3_15_in);

			cv_output1 = 5 * neuroncv3_1_out;	
			cv_output2 = 5 * neuroncv3_2_out;	
			cv_output3 = 5 * neuroncv3_3_out;	
			cv_output4 = 5 * neuroncv3_4_out;	
			cv_output5 = 5 * neuroncv3_5_out;	
			cv_output6 = 5 * neuroncv3_6_out;	
			cv_output7 = 5 * neuroncv3_7_out;	
			cv_output8 = 5 * neuroncv3_8_out;	
			cv_output9 = 5 * neuroncv3_9_out;	
			cv_output10 = 5 * neuroncv3_10_out;	
			cv_output11 = 5 * neuroncv3_11_out;	
			cv_output12 = 5 * neuroncv3_12_out;	
			cv_output13 = 5 * neuroncv3_13_out;	
			cv_output14 = 5 * neuroncv3_14_out;	
			cv_output15 = 5 * neuroncv3_15_out;	
			
	   //****** calculation ends NN5 CV Model******//
			


	   //****** calculation starts Physics Model******//
		 vgs = type * V(G, S);
	   vds = type * V(D, S);

	   //****** Mode choice ******//
	   if (vds >= 0.0)
	     begin 
				 mode = 1.0;
				 vds = vds;
				 vgs = vgs;
			 end
	   else
			 begin
				 mode = -1.0;
				 vds = -vds;
				 vgs = vgs + vds;
	   	 end
		//************************************ Binning ****************************************************//
		//WGAA = WGAA + DeltaWGAA;
		//TGAA = TGAA + DeltaTGAA;
		Inv_L      = 1.0e-6 / Lg;
		Inv_NFIN   = 1.0 / NFIN;
		Inv_LNFIN  = 1.0e-6 / (Lg * NFIN);
		Inv_W      = 1.0e-6 / WGAA;
		Inv_WL     = 1.0e-12 / (WGAA * Lg);
	

		//************************************  Nanosheet gate Start ****************************************************//
    WGAAeff = WGAA; // Assuming WGAA is already defined
    Weff1 = 2 * (WGAAeff + TGAA);
    Ach1 = WGAAeff * TGAA;
    Weff_UFCM = Weff1;
    Ach = Ach1;

    if (NGAA > 1) begin
        Weff2 = 2 * (WGAAeff + TGAA);
        Ach2 = WGAAeff * TGAA;
        Weff_UFCM = Weff1 + Weff2;
        Ach = Ach1 + Ach2;
    end

    if (NGAA > 2) begin
        Weff3 = 2 * (WGAAeff + TGAA);
        Ach3 = WGAAeff * TGAA;
        Weff_UFCM = Weff1 + Weff2 + Weff3;
        Ach = Ach1 + Ach2 + Ach3;
    end

    if (NGAA > 3) begin
        Weff4 = 2 * (WGAAeff + TGAA);
        Ach4 = WGAAeff * TGAA;
        Weff_UFCM = Weff1 + Weff2 + Weff3 + Weff4;
        Ach = Ach1 + Ach2 + Ach3 + Ach4;
    end

    if (NGAA > 4) begin
        Weff5 = 2 * (WGAAeff + TGAA);
        Ach5 = WGAAeff * TGAA;
        Weff_UFCM = Weff1 + Weff2 + Weff3 + Weff4 + Weff5;
        Ach = Ach1 + Ach2 + Ach3 + Ach4 + Ach5;
    end

    if (NGAA > 5) begin
        Weff6 = 2 * (WGAAeff + TGAA);
        Ach6 = WGAAeff * TGAA;
        Weff_UFCM = Weff1 + Weff2 + Weff3 + Weff4 + Weff5 + Weff6;
        Ach = Ach1 + Ach2 + Ach3 + Ach4 + Ach5 + Ach6;
    end

    WeffB = WGAA;

         Weff_UFCM = 2 * (WGAA + DeltaWGAA + TGAA + DeltaTGAA) * NGAA;        //###########1111
         Ach = (WGAA + DeltaWGAA) * (TGAA + DeltaWGAA) * NGAA;                    //###########1111
         EOT = EOT_0*cv_output14;
    Cins = Weff_UFCM * EPSROX * EPS0 / EOT;
		//************************************  Nanosheet gate End ****************************************************//

		//************************************  Geometric scaling for Toxeff / charge centroid Tcen ****************************************************//
    MTcen = 1.0 + AQMTCEN * `lexp(-(2.0 * Ach / Weff_UFCM) / BQMTCEN);
    Tcen0 = (2.0 * Ach / Weff_UFCM) * MTcen;



 

		//************************************   Mobility degradation for GAA Starts ****************************************************//

		// NN4-5 ETAMOB_i
		ETAMOB_i = mob_output5;


		// NN4-1 UA_i
		UA_i = mob_output1;

		// NN4-2 EU_i
		EU_i = mob_output2;



		U0_i = U0 * mob_output3;

		// NN4-4 UD_i
		UD_i = mob_output4; 
		
		Vtm = KboQ * DevTemp;
		nVtm = Vtm;
		Nc = NC0SUB;
		epssub = EPSRSUB * EPS0;
		rc = 2.0 * Cins / (Weff_UFCM * Weff_UFCM * epssub / Ach);
		cox = Cins / Weff_UFCM;
		qbs = q * NBODY_CV * Ach / Cins;
		Qdep_ov_Cins = -q * NBODY_CV * Ach / Cins;
		qdep = Qdep_ov_Cins / nVtm;

		vth_fixed_factor_SI = `lln(Cins * nVtm / (q * Nc * 2.0 * Ach));
		vth_fixed_factor_Sub = `lln((qdep * rc) * (qdep * rc) / ((`lexp(qdep * rc) - qdep * rc - 1.0))) + vth_fixed_factor_SI;
		q0 = 10.0 * nVtm / rc + 2.0 * qbs;
		//************************************   Mobility degradation for GAA Ends ****************************************************//

		//************************************   Short Channel Effect Starts ****************************************************//
		scl = sqrt((epssub * Ach / Cins) * (1.0 + Ach * Cins / (2.0 * epssub * Weff_UFCM * Weff_UFCM)));

		Eg = BG0SUB;
		ni = NI0SUB * `lexp(BG0SUB / (2.0 * KboQ * 300.15) - Eg / (2.0 * Vtm));
		phib = Vtm * `lln(NBODY_CV / ni);

		vbi = Vtm * `lln(NBODY_CV * NSD_CV / (ni * ni));
		// NN1-1 
		tmp = sce_output1 * Lg / scl + 1.0e-6;
		Theta_SCE = 0.5 / (cosh(tmp) - 1.0);
		// NN1-1 
		tmp = sce_output1 * Lg / scl + 1.0e-6;
		Theta_SW = 0.5 / (cosh(tmp) - 1.0);
		// NN1-1 
		tmp = sce_output1 * Lg / scl + 1.0e-6;
		Theta_DIBL = 0.5 / (cosh(tmp) - 1.0);

		Theta_RSCE = sqrt(1.0 + LPE0_i / Lg) - 1.0;

		ThetaSS = `hypsmooth((1.0 - 1.0e-6), 1.0e-3);

		phist = 0.4 + phib + PHIN_i;
		T1 = 2.0 * (Cins / Weff_UFCM) / (rc + 2.0);
		vdsx = sqrt(vds * vds + 0.01) - 0.1;
		// NN1-4:CDSC_i  NN1-5:CDSCD_i 
		cdsc = Theta_SW * (sce_output4 + sce_output5 * vdsx);  
		nVtm = Vtm * ThetaSS * (1.0 + (CIT_i + cdsc) / T1);

		//Quantum mechanical Vth correction
		kT = Vtm * q;
		T0 = HBAR * pi / (2.0 * Ach / Weff_UFCM);
		E0 = T0 * T0 / (2.0 * mx);
		E0prime = T0 * T0 / (2.0 * mxprime);
		E1 = 4.0 * E0;
		E1prime = 4.0 * E0prime;
		T1 = gprime * mdprime / (gfactor * md);
		gam0 = 1.0 + T1 * exp((E0 - E0prime) / kT);
		gam1 = gam0 + `lexp((E0 - E1) / kT) + T1 * `lexp((E0 - E1prime) / kT);
		T2 = -Vtm * `lln(gfactor * md / (pi * HBAR * HBAR * Nc) * kT / (2.0 * Ach / Weff_UFCM) * gam1);
		// NN3-1:QMFACTOR_i  
		dvch_qm = qua_output1 * (E0 / q + T2);

		// NN1-2:DVT0_i  
		dvth_vtroll = -sce_output2 * Theta_SCE * (vbi - phist); 
		// NN1-3:ETA0_i  
		dvth_dibl = -sce_output3 * Theta_DIBL * vdsx + (DVTP0_i * pow(vdsx + 0.01, DVTP1_i));
		dvth_rsce = K1RSCE_i * Theta_RSCE * sqrt(phist);
		dvth_all = dvth_vtroll + dvth_dibl + dvth_rsce + DVTSHIFT;

		deltaPhi = PHIG_CV - EASUB;
		vgsfb = vgs - deltaPhi;
		vgsfbeff = vgsfb - dvth_all;
		//************************************   Short Channel Effect Ends ****************************************************//

		//************************************   Core model calculation at source ****************************************************//
		vch = dvch_qm;
		T4 = pow(-qdep, (2.0 / 3));

		T0 = -qdep + vth_fixed_factor_Sub + QMFACTORCVfinal * T4;
		T1 = -qdep + vth_fixed_factor_SI;

		T2 = (vgsfbeff - vch) / nVtm;
		F0 = -T2 + T1;
		T3 = 0.5 * (T2 - T0);
		qm = `lexp(T3);

		T7 = ln(1.0 + qm);
		qm = 2.0 * (1.0 - sqrt(1.0 + T7 * T7));
		T8 = (qm * ALPHA_UFCM + qdep) * rc;
		T4 = T8 / (exp(T8) - T8 - 1.0);
		T5 = T8 * T4;
		qm_ln = ln(-(qm + qdep));
		e0 = F0 - qm + `lln(-qm) + `lln(T5) + QMFACTORCVfinal * exp((2.0 / 3) * qm_ln);
		e1 = -1.0 + 1.0 / qm + (2.0 / T8 - T4 - 1.0) * rc - 2 / 3 * QMFACTORCVfinal * exp(-(1.0 / 3) * qm_ln);
		e2 = -1.0 / (qm * qm) - (2.0 / 9.0) * QMFACTORCVfinal * exp(-(4.0 / 3) * qm_ln);
		qm = qm - (e0 / e1) * (1.0 + (e0 * e2) / (2.0 * e1 * e1));
		T8 = (qm * ALPHA_UFCM + qdep) * rc;
		T4 = T8 / (`lexp(T8) - T8 - 1.0);
		T5 = T8 * T4;
		qm_ln = ln(-(qm + qdep));
		e0 = F0 - qm + `lln(-qm) + `lln(T5) + QMFACTORCVfinal * exp((2.0 / 3) * qm_ln);
		e1 = -1.0 + 1.0 / qm + (2.0 / T8 - T4 - 1.0) * rc - (2.0 / 3) * QMFACTORCVfinal * exp(-(1.0 / 3) * qm_ln);
		e2 = -1.0 / (qm * qm) - (2.0 / 9.0) * QMFACTORCVfinal * exp(-(4.0 / 3) * qm_ln);
		qm = qm - (e0 / e1) * (1.0 + (e0 * e2) / (2.0 * e1 * e1));

		qis = -qm * nVtm;


		///   Drain-to-source saturation voltage
		eta_mu = 0.5 * ETAMOB_i;
		//eta_mu_cv = 0.5;
		// NN5-1  
		eta_mu_cv = 0.5 * cv_output1;
		EeffFactor = 1.0e-8 / (epsratio * EOT);
		Eeffs = EeffFactor * (qbs + eta_mu * qis);
		qb0 = 1.0e-2 / cox;
		T2 = pow((0.5 * (1.0 + qis / qb0)), UCS_t);
		T3 = pow(Eeffs, EU_i);
		T3 = UA_i * T3 + UD_i / T2;
		Dmobs = 1.0 + T3;
		Dmobs = `smoothminx(Dmobs, 1.0, DMOBCLAMP);
		Dmobs = Dmobs / U0MULT;
		VSAT_a = VSAT;
		// NN2-6
		VSAT_a = VSAT_a * clm_output6;
		Esat = 2.0 * VSAT_a / U0_i * Dmobs;
		EsatL = Esat * Lg;
		KSATIV_a = KSATIV;
		// NN2-7
		KSATIV_a = KSATIV_a * clm_output7;
		T6 = KSATIV_a * (qis + 2.0 * Vtm);
		Vdsat = EsatL * T6 / (EsatL + T6);
		Vdsat = `hypsmooth((Vdsat - 1.0e-3), 1.0e-5) + 1.0e-3;
		MEXP_a = MEXP;
		// NN2-8
		MEXP_a = MEXP_a * clm_output8;
		T7 = pow(((vds / Vdsat) + 1e-6), MEXP_a);
		T8 = pow((1.0 + T7), (1 / MEXP_a));
		Vdseff = min((vds / T8), vds);

		//************************************   Core model calculation at drain ****************************************************//
		vch = Vdseff + dvch_qm;
		T2 = pow((-qdep), (2.0 / 3));

		T0 = -qdep + vth_fixed_factor_Sub + QMFACTORCVfinal * T2;
		T1 = -qdep + vth_fixed_factor_SI;

		T2 = (vgsfbeff - vch) / nVtm;
		F0 = -T2 + T1;
		T3 = (T2 - T0) * 0.5;
		qm = `lexp(T3);

		T7 = ln(1.0 + qm);
		qm = 2.0 * (1.0 - sqrt(1.0 + T7 * T7));
		T8 = (qm * ALPHA_UFCM + qdep) * rc;
		T4 = T8 / (`lexp(T8) - T8 - 1.0);
		T5 = T8 * T4;
		qm_ln = ln(-(qm + qdep));
		e0 = F0 - qm + `lln(-qm) + `lln(T5) + QMFACTORCVfinal * exp((2.0 / 3) * qm_ln);
		e1 = -1.0 + (1.0 / qm) + (2.0 / T8 - T4 - 1.0) * rc - (2.0 / 3) * QMFACTORCVfinal * exp(-(1.0 / 3) * qm_ln);
		e2 = -1.0 / (qm * qm) - (2.0 / 9.0) * QMFACTORCVfinal * exp(-(4.0 / 3) * qm_ln);
		qm = qm - (e0 / e1) * (1.0 + (e0 * e2) / (2.0 * e1 * e1));
		T8 = (qm * ALPHA_UFCM + qdep) * rc;
		T4 = T8 / (`lexp(T8) - T8 - 1.0);
		T5 = T8 * T4;
		qm_ln = ln(-(qm + qdep));
		e0 = F0 - qm + `lln(-qm) + `lln(T5) + QMFACTORCVfinal * exp((2.0 / 3) * qm_ln);
		e1 = -1.0 + (1.0 / qm) + (2.0 / T8 - T4 - 1.0) * rc - (2.0 / 3) * QMFACTORCVfinal * exp(-(1.0 / 3) * qm_ln);
		e2 = -1.0 / (qm * qm) - (2.0 / 9.0) * QMFACTORCVfinal * exp(-(4.0 / 3) * qm_ln);
		qm = qm - (e0 / e1) * (1.0 + (e0 * e2) / (2.0 * e1 * e1));

		qid = -qm * nVtm;

	

		//************************************   Quasi-static I-V model ****************************************************//
		qia = 0.5 * (qis + qid);
		dqi = qis - qid;
		etaiv = q0 / (q0 + qia);
		ids0_ov_dqi = qia + (2.0 - etaiv) * nVtm;
		ids0 = ids0_ov_dqi * dqi;

		//************************************   Channel length modulation ****************************************************//
		Leff = Lg;
		LeffCV = Lg;

		DROUT_i = DROUT;
		// NN2-9
		DROUT_i = DROUT_i * clm_output9;  
		tmp = DROUT_i * Leff / scl + 1.0e-6;

		PDIBL1_a = PDIBL1;
		// NN2-10
		PDIBL1_a = PDIBL1_a * clm_output10;  
		PDIBL2_a = PDIBL2;
		// NN2-11
		PDIBL2_a = PDIBL2_a * clm_output11;  

		DIBLfactor = PDIBL1_a * exp(-tmp) + PDIBL2_a;

		PVAG_i = PVAG;
		// NN2-12
		PVAG_i = PVAG_i * clm_output12;  
		PVAGfactor = 1.0 + PVAG_i * qia / EsatL;
		diffVds = vds - Vdseff;
		Vgst2Vtm = qia + 2.0 * Vtm;
		T1 = Vgst2Vtm;
		T3 = T1 / (Vdsat + T1);
		VaDIBL = T1 / DIBLfactor * T3 * PVAGfactor;
		Moc = 1.0 + diffVds / VaDIBL;
		// NN2-1:PCLM_i 		NN2-5:PCLMG
		T1 = clm_output1 + clm_output5 * qia; 
		Mclm = 1.0 + T1 * `lln(1.0 + (vds - Vdseff) / T1 / (Vdsat + EsatL));
		Moc = Moc * Mclm;

		//************************************   Toxeff model for quantum mechanical effects ****************************************************//
		T4 = qia / QM0;
		T5 = 1.0 + pow(T4, PQM);
		Tcen = Tcen0 / T5;
		// NN3-2  NN3-3 
		//coxeff = 1.0 / (1.0 / (cox * EOT / (TOXP * qua_output2)) + Tcen * QMTCENCV_i * qua_output3 / epssub);
		coxeff = 1.0 / (1.0 / (cox * EOT / (TOXP * qua_output2)) + Tcen * qua_output3 / epssub);

		// Drain current
		cox = Cins / Weff_UFCM;
		beta = U0_i * cox * Weff_UFCM / Lg;


		//************************************   Mobility degradation ****************************************************//
		qia2 = 0.5 * (qis + qid);
		Eeffm = EeffFactor * (qbs + eta_mu * qia2);
		T2 = pow(0.5 * (1.0 + qia2 / qb0), UCS_t);
		T0 = pow(Eeffm, EU_i);
		T3 = UA_i * T0 + UD_i / T2;
		Dmob = 1.0 + T3;
		Dmob = `smoothminx(Dmob, 1.0, DMOBCLAMP);
		Dmob = Dmob / U0MULT;
		ueff = U0_i / Dmob; 

		//************************************   Mobility degradation for C-V ****************************************************//
		Eeffm_cv = EeffFactor * (qbs + eta_mu_cv * qia2);
		T3 = UA_i * pow(Eeffm_cv, EU_i) + UD_i / T2;
		Dmob_cv = 1.0 + T3;
		Dmob_cv = `smoothminx(Dmob_cv, 1.0, DMOBCLAMP);
		Dmob_cv = Dmob_cv / U0MULT;

		//************************************   Current degradation due to velocity saturation ****************************************************//
		VSAT1_a = VSAT1;		
		// NN2-13
		VSAT1_a = VSAT1_a * clm_output13;
		Esat1 = 2.0 * VSAT1_a / ueff;
		Esat1L = Esat1 * Lg;
		// NN2-2: PSAT_i
		T0 = `lexp(clm_output2 * `lln(dqi / Esat1L)); 
		T1 = 1.0 / clm_output2; 
		// NN2-3: DELTAVSAT_i
		Ta = 1.0 + `lexp(T1 * `lln(clm_output3));  
		Dvsat = (1.0 + `lexp(T1 * `lln(clm_output3 + T0))) / Ta; 
		// NN2-4: PTWG_a
		Dvsat = Dvsat + 0.5 * clm_output4 * qia * dqi * dqi;

		//************************************   Non-saturation effect ****************************************************//
		T0 = A1_t + A2_t / (qia + 2.0 * nVtm);
		T1 = T0 * dqi * dqi;
		T2 = T1 + 1.0 - 0.001;
		T3 = -1.0 + 0.5 * (T2 + sqrt(T2 * T2 + 0.004));
		Nsat = 0.5 * (1.0 + sqrt(1.0 + T3));
		Dvsat = Dvsat * Nsat;
		Dvsat = `smoothminx(Dvsat, 1.0, DVSATCLAMP);

		//************************************   Velocity saturation for C-V ****************************************************//

		// NN5-2: PTWG_a
		EsatCV = 2.0 * VSATCV_t * cv_output2 * Dmob_cv / U0_i; 
		EsatCVL = EsatCV * LeffCV;
		// NN5-3: PSATCV_i
		T0 = pow((dqi / EsatCVL), cv_output3);
		T1 = 1.0 / cv_output3;
		// NN5-4: DELTAVSATCV_i
		Ta = 1.0 + pow(cv_output4, T1);
		DvsatCV = (1.0 + pow((cv_output4 + T0), T1)) / Ta;
		// NN5-5: PCLMCV_i
		MclmCV = 1.0 + cv_output5 * `lln(1.0 + (vds - Vdseff) / cv_output5 / (Vdsat + EsatCVL));




		//************************************  GIDL ****************************************************//
		T0 = epsratio * EOT;
		T1 = (-(vgs - vds)) / T0;
		T1 = `hypsmooth(T1, 1.0e-2);
		// NN3-4: BGIDL_i
		T2 = 10 * pow(10.0, 8.0) * gidl_output4 / (T1 + 1.0e-3);
		T3 = pow(T1, 1);
		// NN3-4: AGIDL_i
		T6 = 6.05 * pow(10.0, -12.0) * Weff0 * T3 * `lexp(-T2) * vds * 4 * gidl_output5;
		igidl = T6;
		//igidl_tmp1 = T2;
		//igidl_tmp2 = T3;



		ids = beta * ids0 * Moc / (Dmob * Dvsat) + igidl;
        //ids = beta * ids0 * Moc / (Dmob * Dvsat);           //############1111
		ids_tmp = beta * ids0 * Moc / (Dmob * Dvsat);

		//************************************   Quasi-static C-V model ****************************************************//
		T11 = (2.0 * qia + nVtm) / DvsatCV;
		qg = qia + dqi * dqi / (6.0 * T11);
		qd = -0.5 * (qia - (dqi / 6.0) * (1.0 - (dqi / T11) * (1.0 + dqi / (5.0 * T11))));

		//  CLM in qg and qd
		inv_MclmCV = 1.0 / MclmCV;
		qg = inv_MclmCV * qg + (MclmCV - 1.0) * qid;
		qd = inv_MclmCV * inv_MclmCV * qd + 0.5 * (MclmCV - inv_MclmCV) * qid;
		//$strobe("qg=",qg);
		//$strobe("qd=",qd);
		qs = -qg - qd;
		T6 = WeffCV0 * LeffCV * coxeff * NF;
		qg = T6 * qg;
		qd = T6 * qd;
		qs = T6 * qs;

		//  Bias-dependent overlap capacitances
		CGSO_i = 0.3 * WGAA * cox * cv_output10;            //##########11111
		CGDO_i = 0.3 * WGAA * cox * cv_output13;            //##########11111

		T1 = WeffCV0 * devsign;
		T2 = devsign * vgs;
		T0 = T2 - vfbsdcv + DELTA_1;
		vgs_overlap = 0.5 * (T0 - sqrt(T0 * T0 + 4.0 * DELTA_1));
		qgs_ov = T1 * (CGSL_i * cv_output8 * (T2 - vfbsdcv - vgs_overlap - 0.5 * cv_output9 * (sqrt(1.0 - 4.0 * vgs_overlap / cv_output9) - 1.0)) + CGSO_i * T2);

		T2 = devsign * (vgs - vds);
		T0 = T2 - vfbsdcv + DELTA_1;
		vgd_overlap = 0.5 * (T0 - sqrt(T0 * T0 + 4.0 * DELTA_1));
		qgd_ov = T1 * (CGSL_i * cv_output11 * (T2 - vfbsdcv - vgd_overlap - 0.5 * cv_output12 * (sqrt(1.0 - 4.0 * vgd_overlap / cv_output12) - 1.0)) + CGDO_i * T2);

		T1 = WeffCV0;
		// NN5-6: CFS_i_CV
		qgs_fr = T1 * CFS_i_CV * cv_output6 * vgs;
		// NN5-7: CFD_i
		qgd_fr = T1 * CFD_i_CV * cv_output6 * (vgs - vds);    //#########1111

		qgs_parasitic = qgs_ov + qgs_fr;
		qgd_parasitic = qgd_ov + qgd_fr;

		QG = type * (devsign * qg + qgs_parasitic + qgd_parasitic);
		QG = QG * 0.5;//#########1111
		QD = type * (devsign * qd - qgd_parasitic);
		QD = QD * 0.5;//#########1111
		QS = type * (devsign * qs - qgs_parasitic);
		QS = QS * 0.5;//#########1111

    GM = ddx(ids, V(G));
    GDS = ddx(ids, V(D));

    CGG = ddx(QG, V(G));
    CGD = ddx(QG, V(D));
    CGS = ddx(QG, V(S));
    CDG = ddx(QD, V(G));
    CDD = ddx(QD, V(D));
    CDS = ddx(QD, V(S));
    CSG = ddx(QS, V(G));
    CSD = ddx(QS, V(D));
    CSS = ddx(QS, V(S));




//****** dc current ******//
	   //if (mode > 0.0)
	   //   I(drain, source) <+ type * ids;
	   //else
	   //   I(drain, source) <+ -type * ids;

	   //****charging current******//
	   I(G, S)   <+ ddt(QG);
	   I(D, S)  <+ ddt(QD);




//		V(t2) <+ tmp2_pku;
//		V(t3) <+ tmp3_pku;
//		V(t4) <+ tmp4_pku;
//		V(t5) <+ tmp5_pku;

//		V(t1) <+ CGG;
//		V(t2) <+ CGD;
//		V(t3) <+ tmp3_pku;
//		V(t4) <+ tmp4_pku;
//		V(t5) <+ tmp5_pku;


			end
 


endmodule
